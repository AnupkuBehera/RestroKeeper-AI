        anomalyBanner.classList.remove('hidden');
      } else {
        anomalyBanner.classList.add('hidden');
      }
    }


    // ─── SMART PROCUREMENT VIEW CODE ───
    function initProcureView() {
      refreshProcurementDrafts();
      
      document.getElementById('refresh-po-btn').addEventListener('click', () => {
        if (isBackendOnline) {
          fetchIngredientsFromBackend();
        } else {
          refreshProcurementDrafts();
        }
        showToast('AI Draft orders refreshed!');
      });

      // Modal buttons
      document.getElementById('modal-close-btn').addEventListener('click', closeModal);
      document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);
      document.getElementById('modal-save-btn').addEventListener('click', saveModalItemChanges);
    }

    async function refreshProcurementDrafts() {
      const container = document.getElementById('vendor-panels-container');
      
      let draftResponse = null;

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/procurement/draft-orders`, {
            headers: {
              'X-Tenant-ID': '1'
            }
          });
          if (res.ok) {
            draftResponse = await res.json();
          }
        } catch (e) {
          console.error('Failed to fetch drafts from API:', e);
        }
      }

      if (!draftResponse) {
        // Calculate local forecasts & draft items grouped by vendor
        draftResponse = calculateLocalDraftPOs();
      }

      activePOData = draftResponse.draft_orders;

      // Update analytics stats card
      document.getElementById('stat-critical-alerts').innerText = draftResponse.critical_stock_alerts;
      document.getElementById('stat-pending-orders').innerText = draftResponse.pending_purchase_orders_count;
      document.getElementById('stat-waste-saved').innerText = `$${draftResponse.total_waste_saved_estimate.toFixed(2)}`;

      if (activePOData.length === 0) {
        container.innerHTML = `
          <div class="text-center py-12 text-charcoal-400">
            <svg class="h-12 w-12 text-charcoal-600 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h4 class="text-sm font-semibold text-charcoal-200">Inventory Stocks Fully Stocked</h4>
            <p class="text-xs mt-1">All item levels are currently above their safety thresholds. No replenishment is recommended.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = '';

      activePOData.forEach((vendorPO, vIdx) => {
        let itemsRows = '';
        
        vendorPO.items.forEach((item, itemIdx) => {
          itemsRows += `
            <tr class="border-b border-charcoal-700/30 hover:bg-charcoal-800/20">
              <td class="py-3 font-semibold text-charcoal-50">${item.item_name}</td>
              <td class="py-3 font-mono text-charcoal-400">${item.current_stock} / ${item.safety_par_level} ${item.unit}</td>
              <td class="py-3 font-mono text-charcoal-200">${item.forecasted_demand} ${item.unit}</td>
              <td class="py-3 font-mono text-emerald-500 font-bold">${item.recommended_order_qty} ${item.unit}</td>
              <td class="py-3 font-mono text-charcoal-50 font-bold">$${item.total_cost.toFixed(2)}</td>
              <td class="py-3 text-right">
                <button class="edit-item-btn rounded border border-charcoal-700 hover:border-charcoal-600 bg-charcoal-900 hover:text-charcoal-50 px-2.5 py-1 text-[11px] font-mono transition-all" data-v-idx="${vIdx}" data-item-idx="${itemIdx}">
                  ✏️ Edit
                </button>
              </td>
            </tr>
          `;
        });

        container.innerHTML += `
          <div class="border border-charcoal-700 bg-charcoal-950/20 rounded-xl p-5" id="vendor-panel-${vIdx}">
            <!-- Vendor info -->
            <div class="flex flex-col sm:flex-row justify-between sm:items-center border-b border-charcoal-700 pb-3 mb-4 gap-2">
              <div>
                <span class="text-[10px] text-charcoal-400 font-mono block">SUPPLIER TARGET:</span>
                <span class="text-base font-bold text-charcoal-50 flex items-center gap-1.5">
                  🏢 ${vendorPO.vendor_name}
                </span>
              </div>
              <div class="text-left sm:text-right font-mono">
                <span class="text-[10px] text-charcoal-400 block">TOTAL ORDER COST:</span>
                <span class="text-sm font-bold text-emerald-500" id="vendor-cost-${vIdx}">$${vendorPO.total_order_cost.toFixed(2)}</span>
              </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr class="text-charcoal-400 border-b border-charcoal-700 font-mono">
                    <th class="py-2.5 font-medium">Item Name</th>
                    <th class="py-2.5 font-medium">Stock / Par</th>
                    <th class="py-2.5 font-medium">7-Day Forecast Need</th>
                    <th class="py-2.5 font-medium">Order Quantity</th>
                    <th class="py-2.5 font-medium">Total Cost</th>
                    <th class="py-2.5 font-medium text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-charcoal-700/20">
                  ${itemsRows}
                </tbody>
              </table>
            </div>

            <!-- Actions block -->
            <div class="flex justify-end gap-2.5 mt-5">
              <button class="send-po-btn rounded-lg bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs px-4 py-2 flex items-center gap-1.5 transition-all shadow" data-v-idx="${vIdx}">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
