    // Process spoken/typed text sync
    async function handleTextSync(text) {
      const resultPanel = document.getElementById('sync-results');
      const updatedList = document.getElementById('updated-stock-list');
      updatedList.innerHTML = '';

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/inventory/voice-text-upload`, {
            method: 'POST',
            headers: getHeaders(),
            body: JSON.stringify({ text })
          });

          if (res.ok) {
            const data = await res.json();
            
            if (data.updated_ingredients && data.updated_ingredients.length > 0) {
              resultPanel.classList.remove('hidden');
              data.updated_ingredients.forEach(adj => {
                updatedList.innerHTML += `
                  <li class="flex justify-between items-center text-charcoal-200">
                    <span><strong>${adj.item_name}</strong></span>
                    <span class="text-emerald-400 font-bold">
                      ${adj.old_stock} ➔ ${adj.new_stock} ${adj.unit}
                    </span>
                  </li>
                `;
              });
              showToast(`Synced spoken counts to database & Google Sheets`);
            } else {
              resultPanel.classList.add('hidden');
              showToast('No ingredients matched from voice input.', 'warning');
            }
            await refreshData();
          } else {
            showToast('Voice sync failed on backend', 'error');
          }
        } catch (e) {
          console.error(e);
          showToast('Connection error processing count', 'error');
        }
      } else {
        // Fallback local regex parsing
        const parsed = parseTextSandbox(text);
        if (parsed.length > 0) {
          resultPanel.classList.remove('hidden');
          parsed.forEach(adj => {
            updatedList.innerHTML += `
              <li class="flex justify-between items-center text-charcoal-200">
                <span><strong>${adj.item_name}</strong></span>
                <span class="text-emerald-400 font-bold">
                  ${adj.old_stock} ➔ ${adj.new_stock} ${adj.unit}
                </span>
              </li>
            `;
          });
          showToast(`[Sandbox] Adjusted local stocks`);
          renderInventory();
        } else {
          resultPanel.classList.add('hidden');
          showToast('Failed to parse simulated phrase format.', 'warning');
        }
      }
    }

    // Local JS Regex Matcher for sandbox fallbacks
    function parseTextSandbox(text) {
      const adjustments = [];
      const phrases = text.toLowerCase().split(/[;,\n]|and|then/);
      
      phrases.forEach(phrase => {
        phrase = phrase.trim();
        if (!phrase) return;
        
        const numMatch = phrase.match(/(\d+(?:\.\d+)?)/);
        if (!numMatch) return;
        
        const qty = parseFloat(numMatch[0]);
        const numIdx = phrase.indexOf(numMatch[0]);
        
        let itemQuery = '';
        let unitText = 'units';
        
        const left = phrase.substring(0, numIdx).trim();
        const right = phrase.substring(numIdx + numMatch[0].length).trim();
        
        if (!left || ['i have', 'we have', 'set', 'update', 'add'].includes(left)) {
          const rightClean = right.replace(/^of\s+/, '').trim();
          const words = rightClean.split(' ');
          if (words.length > 1 && ['bags', 'kg', 'boxes', 'packets', 'blocks'].includes(words[0])) {
            unitText = words[0];
            itemQuery = words.slice(1).join(' ');
          } else {
            itemQuery = rightClean;
          }
        } else {
          itemQuery = left.replace(/^(set|update|add|change)\s+/, '').replace(/\s+to$/, '');
          const words = right.split(' ');
          if (words.length > 0) {
            unitText = words[0];
          }
        }

        itemQuery = itemQuery.trim();
        if (!itemQuery) return;

        let bestMatch = null;
        let highestScore = 0;
        
        localIngredients.forEach(ing => {
          const nameLower = ing.item_name.toLowerCase();
          let score = 0;
          if (nameLower === itemQuery) {
            score = 100;
          } else if (nameLower.includes(itemQuery) || itemQuery.includes(nameLower)) {
            score = 70;
          }
          
          if (score > highestScore) {
            highestScore = score;
            bestMatch = ing;
          }
        });

        if (bestMatch && highestScore >= 70) {
          const oldStock = bestMatch.current_stock;
          bestMatch.current_stock = qty;
          adjustments.push({
            item_name: bestMatch.item_name,
            old_stock: oldStock,
            new_stock: qty,
            unit: bestMatch.unit_type
          });
        }
      });

      return adjustments;
    }

