---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Header Navbar -->
  <header class="sticky top-0 z-40 border-b border-charcoal-700 bg-charcoal-900/85 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500 text-charcoal-950 font-bold tracking-tight">
          RK
        </div>
        <div>
          <span class="text-lg font-semibold tracking-tight text-charcoal-50">RestoKeeper <span class="text-emerald-500 font-bold">AI</span></span>
          <span class="block text-[10px] text-charcoal-400 font-mono tracking-wider uppercase">Restaurant Inventory Manager</span>
        </div>
      </div>

      <!-- Server & Sheets Status Badge -->
      <div class="flex items-center gap-3">
        <!-- Backend API Status -->
        <div id="backend-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs">
          <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse" id="backend-dot"></span>
          <span class="text-charcoal-400 font-mono text-[11px]" id="backend-text">Checking API...</span>
        </div>
        <!-- Google Sheets Sync Status -->
        <div id="sheets-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs cursor-pointer hover:border-charcoal-600 transition-all" title="Click to view Sheets details">
          <svg class="h-3.5 w-3.5 text-charcoal-400" id="sheets-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-charcoal-400 font-mono text-[11px]" id="sheets-text">Sheets: Sandbox</span>
        </div>
        <!-- Reset Database Button -->
        <button id="demo-reset-btn" class="flex items-center gap-1.5 rounded-md border border-charcoal-700 hover:border-charcoal-600 bg-charcoal-900 px-3 py-1.5 text-xs text-charcoal-200 hover:text-charcoal-50 font-medium transition-all" title="Reset stocks to default metrics">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
          </svg>
          Reset Demo
        </button>
      </div>
    </div>
  </header>

  <!-- Google Sheet Sync Status Drawer -->
  <div id="sheets-info-drawer" class="hidden mx-auto max-w-7xl px-4 mt-4 sm:px-6 lg:px-8">
    <div class="bg-charcoal-800 border border-charcoal-700 rounded-xl p-4 text-xs font-mono text-charcoal-300 space-y-2.5 shadow-2xl">
      <div class="flex justify-between items-center text-charcoal-200 border-b border-charcoal-700 pb-2">
        <span class="font-bold uppercase text-[10px] tracking-wider text-emerald-500 flex items-center gap-1">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Google Sheets Sync status
        </span>
        <button id="close-sheets-drawer" class="text-charcoal-400 hover:text-charcoal-200 cursor-pointer">✕ Close</button>
      </div>
      <p>
        1. Open your target Google Sheet and share it with edit access to this Service Account:
        <br />
        <code class="bg-charcoal-900 text-emerald-400 px-2 py-1 rounded block mt-1 select-all select-text font-semibold font-mono" id="sheets-email-display">gcp-service-account@not-configured.iam.gserviceaccount.com</code>
      </p>
      <p>
        2. Set these environment variables in your backend <code class="bg-charcoal-900 text-charcoal-100 px-1 rounded select-all font-mono">.env</code> configuration:
        <code class="bg-charcoal-900 text-charcoal-400 p-2 rounded block mt-1 leading-relaxed font-mono">
          GOOGLE_SHEET_ID=your_google_sheet_id_here
          <br />
          GOOGLE_SHEETS_CREDENTIALS_JSON=paste_service_account_json_content_here
        </code>
      </p>
      <div class="pt-2 border-t border-charcoal-700/50 flex items-center justify-between">
        <span>Spreadsheet status: <strong id="sheets-drawer-status" class="text-amber-500 font-semibold font-mono">Sandbox Simulation (Offline Cache)</strong></span>
        <a href="#" id="sheets-link-url" target="_blank" class="hidden text-emerald-500 hover:text-emerald-400 underline font-bold flex items-center gap-1 transition-all">
          Open Spreadsheet 🔗
        </a>
      </div>
    </div>
  </div>

  <!-- Main Container -->
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 space-y-6">

    <!-- RESTOCK ALERTS BOX (Pulsing Alerts Banner at Top) -->
    <div id="restock-alerts-container" class="hidden rounded-xl border border-rose-500/30 bg-rose-950/15 p-4 shadow-md">
      <div class="flex items-start gap-3">
        <div class="h-8 w-8 rounded-full bg-rose-500/10 flex items-center justify-center text-rose-500 flex-shrink-0 animate-pulse">
          ⚠️
        </div>
        <div class="flex-1">
          <h4 class="text-sm font-bold text-rose-500 font-mono tracking-wide uppercase">RE-STOCK ALERTS: Low Inventory Levels Detected</h4>
          <p class="text-xs text-charcoal-400 mt-0.5">The following ingredients have fallen below their safety par levels and need to be ordered:</p>
          <ul id="restock-alerts-list" class="mt-2.5 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2 text-xs font-mono">
            <!-- Dynamically populated low stock alerts -->
          </ul>
        </div>
      </div>
    </div>

    <!-- Dashboard Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

      <!-- LEFT COLUMN: Voice / Text Update Panel (lg:span-5) -->
      <section class="lg:col-span-5 space-y-6">
        
        <!-- Voice & Type Stock Count Card -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Voice & Type Stock Auditor</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Quick update quantities by speaking or typing</p>
          </div>

          <div class="p-6 flex flex-col items-center">
            
            <!-- Real-time Voice Transcription Button -->
            <div class="relative my-4 flex flex-col items-center justify-center">
              <button id="mic-record-btn" class="h-28 w-28 rounded-full bg-charcoal-700 border-4 border-charcoal-600 flex items-center justify-center text-charcoal-50 hover:text-emerald-500 transition-all shadow-lg hover:scale-105 active:scale-95 cursor-pointer z-10">
                <svg id="mic-icon" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                </svg>
              </button>
              <div id="mic-pulse-ring" class="hidden absolute top-0 left-0 h-28 w-28 rounded-full border border-emerald-500/50 animate-mic-pulse"></div>
              
              <span id="mic-status-label" class="mt-4 text-xs font-semibold text-charcoal-400 font-mono tracking-wider">TAP TO VOICE COUNT</span>
            </div>

            <!-- Voice Ticker / Live feedback -->
            <div id="voice-ticker" class="w-full text-center text-xs font-mono italic text-emerald-400 min-h-[20px] mb-4">
              Standing by... Speak your counts or type below.
            </div>

            <!-- Text Box Input for Typed / Transcribed queries -->
            <div class="w-full space-y-2">
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider">Spoken Transcription / Typed Counts</label>
              <textarea id="inventory-text-input" placeholder='e.g., Atta 5 bags, Dal 12 kg, Rice 10 bags' rows="3" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-xl p-3 text-sm text-charcoal-50 focus:outline-none focus:border-emerald-500 font-mono"></textarea>
              <button id="process-stock-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-sm py-2.5 rounded-xl transition-all shadow-md">
                Update Stock counts & Sync
              </button>
            </div>

            <!-- Synced Stock adjustments feedback list -->
            <div id="sync-results" class="w-full mt-4 hidden">
              <div class="rounded-xl border border-emerald-500/20 bg-emerald-950/10 p-4">
                <span class="text-[10px] font-bold text-emerald-500 font-mono uppercase block mb-2">Synced Stock Adjustments:</span>
                <ul class="space-y-1.5 text-xs font-mono" id="updated-stock-list">
                  <!-- Synced updates -->
                </ul>
              </div>
            </div>

            <!-- Simulation Count Shortcuts -->
            <div class="w-full border-t border-charcoal-700 pt-4 mt-6">
              <span class="text-[10px] font-semibold text-charcoal-400 font-mono tracking-wider block mb-2 uppercase">Quick Simulation Shortcuts:</span>
              <div class="flex flex-col gap-1.5">
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Dal 12 kg, Atta 8 bags">
                  <span>"Dal 12 kg, Atta 8 bags"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Fill Atta & Dal</span>
                </button>
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Rice 10 bags, Potato 25 kg">
                  <span>"Rice 10 bags, Potato 25 kg"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Increase Rice & Potato</span>
                </button>
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Sugar 8 kg">
                  <span>"Sugar 8 kg"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Replenish Sugar</span>
                </button>
              </div>
            </div>

          </div>
        </div>

        <!-- Add Custom Ingredient SKU Form -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4 flex justify-between items-center">
            <h2 class="text-base font-semibold text-charcoal-50">Register New Ingredient SKU</h2>
            <button id="toggle-add-form" class="text-xs text-emerald-500 font-bold hover:underline">Toggle Form</button>
          </div>

          <div id="add-ing-form" class="p-6 space-y-3.5 hidden">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Item Name</label>
              <input type="text" id="new-ing-name" placeholder="e.g. Garlic" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
            </div>
            <div class="grid grid-cols-2 gap-2.5">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">SKU Code</label>
                <input type="text" id="new-ing-sku" placeholder="SKU-GAR-07" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Unit Type</label>
                <input type="text" id="new-ing-unit" placeholder="kg, bags, boxes" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-2.5">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Safety Par Level</label>
                <input type="number" id="new-ing-par" placeholder="10" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Cost / Unit ($)</label>
                <input type="number" id="new-ing-cost" placeholder="3.50" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Supplier Name</label>
              <input type="text" id="new-ing-vendor" placeholder="Fresh Produce Co." class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
            </div>
            <button id="save-new-ing-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
              Save Ingredient SKU & Sync
            </button>
          </div>
        </div>

      </section>

      <!-- RIGHT COLUMN: Stock Inventory list & Inline Edits (lg:span-7) -->
      <section class="lg:col-span-7">
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          
          <!-- Card Header -->
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
              <h2 class="text-base font-semibold text-charcoal-50">Master Ingredient Inventory</h2>
              <p class="text-xs text-charcoal-400 mt-0.5">Directly edit quantities in the table to synchronize instantly</p>
            </div>
            <div class="flex items-center gap-2">
              <button id="clear-stocks-btn" class="rounded-md border border-rose-500/30 hover:bg-rose-950/20 bg-charcoal-900 px-3 py-1.5 text-xs text-rose-500 font-medium transition-all" title="Clear all stock levels to 0.0 for fresh count">
                🗑️ Clear Stocks
              </button>
            </div>
          </div>

          <!-- Inventory Table Container -->
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-xs font-mono">
              <thead>
                <tr class="border-b border-charcoal-700 bg-charcoal-900/40 text-charcoal-400 text-[10px] tracking-wider uppercase">
                  <th class="p-4 font-semibold">SKU / Item</th>
                  <th class="p-4 font-semibold text-center">Current Stock</th>
                  <th class="p-4 font-semibold text-center">Par Level</th>
                  <th class="p-4 font-semibold">Cost & Supplier</th>
                  <th class="p-4 font-semibold text-center">Status</th>
                  <th class="p-4 font-semibold text-center">Action</th>
                </tr>
              </thead>
              <tbody id="inventory-table-tbody" class="divide-y divide-charcoal-700/50">
                <!-- Dynamically populated inventory rows -->
              </tbody>
            </table>
          </div>

        </div>
      </section>

    </div>

  </main>

  <!-- Simple Toast Notifications -->
  <div id="toast" class="fixed bottom-4 right-4 z-50 transform translate-y-10 opacity-0 bg-charcoal-800 border border-charcoal-700 text-charcoal-50 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300">
    <span id="toast-message">Stock levels updated.</span>
  </div>
</Layout>

<script is:inline>
  (function () {
    const BACKEND_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' 
      ? 'http://localhost:8000' 
      : window.location.origin;
    let isBackendOnline = false;
    let localIngredients = [
      { id: 1, SKU_code: 'SKU-ATT-01', item_name: 'Atta', current_stock: 2.0, safety_par_level: 5.0, unit_type: 'bags', cost_per_unit: 12.00, vendor_name: 'Desi Grains Co.' },
      { id: 2, SKU_code: 'SKU-DAL-02', item_name: 'Dal', current_stock: 8.0, safety_par_level: 10.0, unit_type: 'kg', cost_per_unit: 4.50, vendor_name: 'Desi Grains Co.' },
      { id: 3, SKU_code: 'SKU-RIC-03', item_name: 'Rice', current_stock: 3.0, safety_par_level: 8.0, unit_type: 'bags', cost_per_unit: 18.00, vendor_name: 'Desi Grains Co.' },
      { id: 4, SKU_code: 'SKU-ONN-04', item_name: 'Onions', current_stock: 18.0, safety_par_level: 15.0, unit_type: 'kg', cost_per_unit: 2.50, vendor_name: 'Fresh Produce Co.' },
      { id: 5, SKU_code: 'SKU-POT-05', item_name: 'Potato', current_stock: 12.0, safety_par_level: 20.0, unit_type: 'kg', cost_per_unit: 1.80, vendor_name: 'Fresh Produce Co.' },
      { id: 6, SKU_code: 'SKU-SUG-06', item_name: 'Sugar', current_stock: 4.0, safety_par_level: 10.0, unit_type: 'kg', cost_per_unit: 3.00, vendor_name: 'Sysco' }
    ];

    // Initialize application
    document.addEventListener('DOMContentLoaded', async () => {
      await checkBackendHealth();
      await fetchSheetsConfig();
      await fetchIngredients();

      initSpeechRecognition();
      setupEventListeners();
    });

    // Toast Alert Helper
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-message');
      toastMsg.innerText = message;
      
      if (type === 'error') {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-rose-955 border border-rose-500/30 text-rose-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      } else if (type === 'warning') {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-amber-955 border border-amber-500/30 text-amber-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      } else {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-charcoal-800 border border-emerald-500/30 text-emerald-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      }

      setTimeout(() => {
        toast.className = 'fixed bottom-4 right-4 z-50 transform translate-y-10 opacity-0 bg-charcoal-800 border border-charcoal-700 text-charcoal-50 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300';
      }, 3500);
    }

    // Health check endpoint
    async function checkBackendHealth() {
      const dot = document.getElementById('backend-dot');
      const text = document.getElementById('backend-text');
      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/health`);
        if (res.ok) {
          isBackendOnline = true;
          dot.className = 'h-2 w-2 rounded-full bg-emerald-500';
          text.innerText = 'API: Connected';
        } else {
          throw new Error('API offline');
        }
      } catch (e) {
        isBackendOnline = false;
        dot.className = 'h-2 w-2 rounded-full bg-rose-500 animate-pulse';
        text.innerText = 'API: Sandbox';
        showToast('Running in Sandbox Mode (Offline Cache)', 'warning');
      }
    }

    // Sheets config loader
    async function fetchSheetsConfig() {
      const badge = document.getElementById('sheets-text');
      const icon = document.getElementById('sheets-icon');
      const drawerStatus = document.getElementById('sheets-drawer-status');
      const emailDisplay = document.getElementById('sheets-email-display');
      const linkUrl = document.getElementById('sheets-link-url');

      if (!isBackendOnline) {
        badge.innerText = 'Sheets: Sandbox';
        badge.className = 'text-charcoal-400 font-mono text-[11px]';
        drawerStatus.innerText = 'Sandbox Simulation (Offline Cache)';
        drawerStatus.className = 'text-amber-500 font-semibold font-mono';
        return;
      }

      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/sheets/config`);
        if (res.ok) {
          const config = await res.json();
          if (config.is_mock) {
            badge.innerText = 'Sheets: Sandbox';
            badge.className = 'text-charcoal-400 font-mono text-[11px]';
            drawerStatus.innerText = 'Sandbox Simulation (Offline Cache)';
            drawerStatus.className = 'text-amber-500 font-semibold';
            linkUrl.classList.add('hidden');
          } else {
            badge.innerText = 'Sheets: Linked';
            badge.className = 'text-emerald-500 font-mono text-[11px]';
            icon.setAttribute('class', 'h-3.5 w-3.5 text-emerald-500');
            drawerStatus.innerText = 'Linked & Synchronizing';
            drawerStatus.className = 'text-emerald-500 font-semibold';
            emailDisplay.innerText = config.share_email;
            linkUrl.href = `https://docs.google.com/spreadsheets/d/${config.sheet_id}`;
            linkUrl.classList.remove('hidden');
          }
        }
      } catch (e) {
        console.error(e);
      }
    }

    // Get ingredients
    async function fetchIngredients() {
      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients`, {
            headers: { 'X-Tenant-ID': '1' }
          });
          if (res.ok) {
            localIngredients = await res.json();
          }
        } catch (e) {
          console.error('Failed to fetch backend ingredients', e);
        }
      }
      renderInventory();
    }

    // Render alerts & table rows
    function renderInventory() {
      const alertsList = document.getElementById('restock-alerts-list');
      const alertsContainer = document.getElementById('restock-alerts-container');
      const tbody = document.getElementById('inventory-table-tbody');
      
      alertsList.innerHTML = '';
      tbody.innerHTML = '';

      let lowStockItemsCount = 0;

      localIngredients.forEach(ing => {
        const isLow = ing.current_stock < ing.safety_par_level;
        
        // Add to low-stock alert panel
        if (isLow) {
          lowStockItemsCount++;
          alertsList.innerHTML += `
            <li class="flex items-center justify-between border border-rose-500/20 bg-rose-955/20 rounded-lg p-2.5 text-rose-300">
              <span><strong>${ing.item_name}</strong> (${ing.SKU_code})</span>
              <span class="bg-rose-500/10 px-2 py-0.5 rounded text-[10px] font-bold">
                Stock: ${ing.current_stock} / Par: ${ing.safety_par_level} ${ing.unit_type}
              </span>
            </li>
          `;
        }

        // Add to table
        const rowClass = isLow ? 'bg-amber-955/5 border-l-2 border-l-amber-500/40 hover:bg-amber-955/10' : 'hover:bg-charcoal-700/30';
        const badgeClass = isLow ? 'bg-rose-955 border border-rose-500/30 text-rose-500 animate-pulse' : 'bg-emerald-955 border border-emerald-500/30 text-emerald-500';
        const badgeText = isLow ? 'LOW STOCK' : 'NORMAL';

        tbody.innerHTML += `
          <tr class="${rowClass} transition-colors border-b border-charcoal-700/40">
            <td class="p-4">
              <span class="font-bold text-charcoal-50 block">${ing.item_name}</span>
              <span class="text-[10px] text-charcoal-400 font-mono">${ing.SKU_code}</span>
            </td>
            <td class="p-4 text-center">
              <div class="flex items-center justify-center gap-1.5">
                <input type="number" step="0.1" value="${ing.current_stock}" 
                  class="stock-inline-input w-16 bg-charcoal-900 border border-charcoal-700 rounded px-1.5 py-1 text-center font-bold text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" 
                  data-id="${ing.id}" data-sku="${ing.SKU_code}" />
                <span class="text-charcoal-400 text-[10px] font-mono select-none">${ing.unit_type}</span>
              </div>
            </td>
            <td class="p-4 text-center text-charcoal-200">
              ${ing.safety_par_level} <span class="text-charcoal-400 text-[10px]">${ing.unit_type}</span>
            </td>
            <td class="p-4 text-charcoal-300">
              <span class="block text-xs font-semibold">$${ing.cost_per_unit.toFixed(2)} / unit</span>
              <span class="text-[10px] text-charcoal-400 truncate max-w-[120px] block">${ing.vendor_name}</span>
            </td>
            <td class="p-4 text-center">
              <span class="inline-block px-2.5 py-0.5 rounded text-[9px] font-bold tracking-wider ${badgeClass}">
                ${badgeText}
              </span>
            </td>
            <td class="p-4 text-center">
              <button class="save-inline-btn bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 rounded p-1.5 font-bold transition-all" 
                data-id="${ing.id}" title="Save inline stock level">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            </td>
          </tr>
        `;
      });

      // Show alert box if any items are low
      if (lowStockItemsCount > 0) {
        alertsContainer.classList.remove('hidden');
      } else {
        alertsContainer.classList.add('hidden');
      }

      // Re-attach inline save buttons event listeners
      document.querySelectorAll('.save-inline-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const id = parseInt(btn.getAttribute('data-id'));
          // Find input with same id
          const input = document.querySelector(`.stock-inline-input[data-id="${id}"]`);
          if (input) {
            const stock = parseFloat(input.value);
            if (!isNaN(stock)) {
              await updateSingleStock(id, stock);
            }
          }
        });
      });

      // Support hitting Enter in inline inputs
      document.querySelectorAll('.stock-inline-input').forEach(input => {
        input.addEventListener('keydown', async (e) => {
          if (e.key === 'Enter') {
            const id = parseInt(input.getAttribute('data-id'));
            const stock = parseFloat(input.value);
            if (!isNaN(stock)) {
              await updateSingleStock(id, stock);
            }
          }
        });
      });
    }

    // Save individual stock update
    async function updateSingleStock(id, stock) {
      const item = localIngredients.find(i => i.id === id);
      if (!item) return;

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/${id}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              'X-Tenant-ID': '1'
            },
            body: JSON.stringify({ current_stock: stock })
          });
          if (res.ok) {
            const updated = await res.json();
            item.current_stock = updated.current_stock;
            showToast(`Updated ${item.item_name} stock to ${stock} ${item.unit_type}`);
            renderInventory();
          } else {
            showToast('Failed to sync stock updates', 'error');
          }
        } catch (e) {
          console.error(e);
          showToast('Connection error updating stock', 'error');
        }
      } else {
        // Sandbox local state update
        item.current_stock = stock;
        showToast(`[Sandbox] Set ${item.item_name} stock to ${stock} ${item.unit_type}`);
        renderInventory();
      }
    }

    // Speech-to-text setup
    function initSpeechRecognition() {
      const recordBtn = document.getElementById('mic-record-btn');
      const micPulseRing = document.getElementById('mic-pulse-ring');
      const micStatusLabel = document.getElementById('mic-status-label');
      const voiceTicker = document.getElementById('voice-ticker');
      const textArea = document.getElementById('inventory-text-input');

      let recognition = null;
      let isRecording = false;

      if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.continuous = false;
        recognition.interimResults = true;
        recognition.lang = 'en-US';

        recognition.onstart = () => {
          isRecording = true;
          recordBtn.classList.remove('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
          recordBtn.classList.add('bg-rose-500', 'border-rose-600', 'text-charcoal-950');
          micPulseRing.classList.remove('hidden');
          micStatusLabel.innerText = 'LISTENING...';
          micStatusLabel.className = 'mt-4 text-xs font-bold text-rose-500 font-mono tracking-wider animate-pulse';
          voiceTicker.innerText = 'Listening to speech... Speak counts (e.g. "Dal 12 kg and Atta 8 bags").';
        };

        recognition.onresult = (event) => {
          let interimTranscript = '';
          let finalTranscript = '';
          for (let i = event.resultIndex; i < event.results.length; ++i) {
            if (event.results[i].isFinal) {
              finalTranscript += event.results[i][0].transcript;
            } else {
              interimTranscript += event.results[i][0].transcript;
            }
          }
          const textToShow = finalTranscript || interimTranscript;
          voiceTicker.innerText = `"${textToShow}"`;
          if (finalTranscript) {
            textArea.value = finalTranscript;
          }
        };

        recognition.onerror = (event) => {
          console.error('Speech recognition error:', event.error);
          voiceTicker.innerText = `Speech error: ${event.error}. Please type.`;
        };

        recognition.onend = () => {
          isRecording = false;
          recordBtn.classList.add('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
          recordBtn.classList.remove('bg-rose-500', 'border-rose-600', 'text-charcoal-950');
          micPulseRing.classList.add('hidden');
          micStatusLabel.innerText = 'TAP TO VOICE COUNT';
          micStatusLabel.className = 'mt-4 text-xs font-semibold text-charcoal-400 font-mono tracking-wider';
          if (!textArea.value.trim()) {
            voiceTicker.innerText = 'Speech finished. Input field empty.';
          } else {
            voiceTicker.innerText = 'Speech transcribed! Review or edit text below.';
          }
        };

        recordBtn.addEventListener('click', () => {
          if (isRecording) {
            recognition.stop();
          } else {
            textArea.value = '';
            recognition.start();
          }
        });
      } else {
        // Fallback for unsupported browsers
        recordBtn.addEventListener('click', () => {
          showToast('Voice Recognition is not supported by your browser. Please type or use simulation shortcuts.', 'warning');
          voiceTicker.innerText = 'Web Speech recognition not supported. Please type instead.';
        });
      }
    }

    // Setup other events
    function setupEventListeners() {
      const sheetsStatus = document.getElementById('sheets-status');
      const sheetsDrawer = document.getElementById('sheets-info-drawer');
      const closeDrawer = document.getElementById('close-sheets-drawer');
      const toggleAddFormBtn = document.getElementById('toggle-add-form');
      const addForm = document.getElementById('add-ing-form');

      // Sync sheets drawer visibility
      sheetsStatus.addEventListener('click', () => {
        sheetsDrawer.classList.toggle('hidden');
      });
      closeDrawer.addEventListener('click', () => {
        sheetsDrawer.classList.add('hidden');
      });

      // Toggle Custom Add form
      toggleAddFormBtn.addEventListener('click', () => {
        addForm.classList.toggle('hidden');
        if (addForm.classList.contains('hidden')) {
          toggleAddFormBtn.innerText = 'Toggle Form';
        } else {
          toggleAddFormBtn.innerText = '✕ Close Form';
        }
      });

      // Quick simulations
      document.querySelectorAll('.voice-sim-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const phrase = btn.getAttribute('data-phrase');
          document.getElementById('inventory-text-input').value = phrase;
          document.getElementById('voice-ticker').innerText = `"${phrase}" (Simulated Phrase copied)`;
          handleTextSync(phrase);
        });
      });

      // Submit spoken/typed counts
      document.getElementById('process-stock-btn').addEventListener('click', () => {
        const text = document.getElementById('inventory-text-input').value.trim();
        if (text) {
          handleTextSync(text);
        } else {
          showToast('Please type a query or speak first.', 'warning');
        }
      });

      // Global Reset Demo
      document.getElementById('demo-reset-btn').addEventListener('click', async () => {
        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/reset`, {
              method: 'POST',
              headers: { 'X-Tenant-ID': '1' }
            });
            if (res.ok) {
              showToast('Database reset to standard items & stocks');
              await fetchIngredients();
            } else {
              showToast('Reset failed', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('API reset call failed', 'error');
          }
        } else {
          // Reset local copy
          localIngredients = [
            { id: 1, SKU_code: 'SKU-ATT-01', item_name: 'Atta', current_stock: 2.0, safety_par_level: 5.0, unit_type: 'bags', cost_per_unit: 12.00, vendor_name: 'Desi Grains Co.' },
            { id: 2, SKU_code: 'SKU-DAL-02', item_name: 'Dal', current_stock: 8.0, safety_par_level: 10.0, unit_type: 'kg', cost_per_unit: 4.50, vendor_name: 'Desi Grains Co.' },
            { id: 3, SKU_code: 'SKU-RIC-03', item_name: 'Rice', current_stock: 3.0, safety_par_level: 8.0, unit_type: 'bags', cost_per_unit: 18.00, vendor_name: 'Desi Grains Co.' },
            { id: 4, SKU_code: 'SKU-ONN-04', item_name: 'Onions', current_stock: 18.0, safety_par_level: 15.0, unit_type: 'kg', cost_per_unit: 2.50, vendor_name: 'Fresh Produce Co.' },
            { id: 5, SKU_code: 'SKU-POT-05', item_name: 'Potato', current_stock: 12.0, safety_par_level: 20.0, unit_type: 'kg', cost_per_unit: 1.80, vendor_name: 'Fresh Produce Co.' },
            { id: 6, SKU_code: 'SKU-SUG-06', item_name: 'Sugar', current_stock: 4.0, safety_par_level: 10.0, unit_type: 'kg', cost_per_unit: 3.00, vendor_name: 'Sysco' }
          ];
          showToast('[Sandbox] Reset local values to defaults');
          renderInventory();
        }
      });

      // Clear Stocks event
      document.getElementById('clear-stocks-btn').addEventListener('click', async () => {
        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/clear-stocks`, {
              method: 'POST',
              headers: { 'X-Tenant-ID': '1' }
            });
            if (res.ok) {
              showToast('Database stocks cleared to 0.0');
              await fetchIngredients();
            } else {
              showToast('Clear failed', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('API clear call failed', 'error');
          }
        } else {
          localIngredients.forEach(ing => ing.current_stock = 0.0);
          showToast('[Sandbox] Cleared local stock caches');
          renderInventory();
        }
      });

      // Save custom SKU
      document.getElementById('save-new-ing-btn').addEventListener('click', async () => {
        const name = document.getElementById('new-ing-name').value.trim();
        const sku = document.getElementById('new-ing-sku').value.trim();
        const unit = document.getElementById('new-ing-unit').value.trim();
        const par = parseFloat(document.getElementById('new-ing-par').value);
        const cost = parseFloat(document.getElementById('new-ing-cost').value);
        const vendor = document.getElementById('new-ing-vendor').value.trim();

        if (!name || !sku || !unit || isNaN(par) || isNaN(cost) || !vendor) {
          showToast('Please fill out all custom fields.', 'error');
          return;
        }

        const payload = {
          SKU_code: sku,
          item_name: name,
          current_stock: 0.0,
          safety_par_level: par,
          unit_type: unit,
          cost_per_unit: cost,
          vendor_name: vendor
        };

        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Tenant-ID': '1'
              },
              body: JSON.stringify(payload)
            });
            if (res.ok) {
              showToast(`Registered SKU ${sku} (${name})`);
              
              // Clear fields
              document.getElementById('new-ing-name').value = '';
              document.getElementById('new-ing-sku').value = '';
              document.getElementById('new-ing-unit').value = '';
              document.getElementById('new-ing-par').value = '';
              document.getElementById('new-ing-cost').value = '';
              document.getElementById('new-ing-vendor').value = '';
              addForm.classList.add('hidden');
              toggleAddFormBtn.innerText = 'Toggle Form';

              await fetchIngredients();
            } else {
              const err = await res.json();
              showToast(err.detail || 'Failed to save item', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('API save custom item failed', 'error');
          }
        } else {
          // Push locally
          const newId = localIngredients.length + 1;
          localIngredients.push({ id: newId, ...payload });
          showToast(`[Sandbox] Saved ${name} locally`);
          
          document.getElementById('new-ing-name').value = '';
          document.getElementById('new-ing-sku').value = '';
          document.getElementById('new-ing-unit').value = '';
          document.getElementById('new-ing-par').value = '';
          document.getElementById('new-ing-cost').value = '';
          document.getElementById('new-ing-vendor').value = '';
          addForm.classList.add('hidden');
          toggleAddFormBtn.innerText = 'Toggle Form';

          renderInventory();
        }
      });
    }

    // Process typed / transcript counts text
    async function handleTextSync(text) {
      const resultPanel = document.getElementById('sync-results');
      const updatedList = document.getElementById('updated-stock-list');
      
      updatedList.innerHTML = '';

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/inventory/voice-text-upload`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Tenant-ID': '1'
            },
            body: JSON.stringify({ text })
          });

          if (res.ok) {
            const data = await res.json();
            
            if (data.updated_ingredients && data.updated_ingredients.length > 0) {
              resultPanel.classList.remove('hidden');
              data.updated_ingredients.forEach(adj => {
                updatedList.innerHTML += `
                  <li class="flex justify-between items-center text-charcoal-200">
                    <span><strong>${adj.item_name}</strong></span>
                    <span class="text-emerald-400 font-bold">
                      ${adj.old_stock} ➔ ${adj.new_stock} ${adj.unit}
                    </span>
                  </li>
                `;
              });
              showToast(`Successfully synced counts to DB & Sheets`);
            } else {
              resultPanel.classList.add('hidden');
              showToast('No matching items parsed from text.', 'warning');
            }
            
            // Reload ingredients from backend
            await fetchIngredients();
          } else {
            showToast('Backend text sync failed', 'error');
          }
        } catch (e) {
          console.error(e);
          showToast('Connection error processing count', 'error');
        }
      } else {
        // Parse locally using a simple JS regex matcher for Sandbox Mode!
        const parsed = parseTextSandbox(text);
        if (parsed.length > 0) {
          resultPanel.classList.remove('hidden');
          parsed.forEach(adj => {
            updatedList.innerHTML += `
              <li class="flex justify-between items-center text-charcoal-200">
                <span><strong>${adj.item_name}</strong></span>
                <span class="text-emerald-400 font-bold">
                  ${adj.old_stock} ➔ ${adj.new_stock} ${adj.unit}
                </span>
              </li>
            `;
          });
          showToast(`[Sandbox] Synced stock adjustments locally`);
          renderInventory();
        } else {
          resultPanel.classList.add('hidden');
          showToast('No items parsed. Use format: "[Item] [Qty]"', 'warning');
        }
      }
    }

    // Local JS Regex Matcher for sandbox fallbacks
    function parseTextSandbox(text) {
      const adjustments = [];
      const phrases = text.toLowerCase().split(/[;,\n]|and|then/);
      
      phrases.forEach(phrase => {
        phrase = phrase.trim();
        if (!phrase) return;
        
        // Find quantity
        const numMatch = phrase.match(/(\d+(?:\.\d+)?)/);
        if (!numMatch) return;
        
        const qty = parseFloat(numMatch[0]);
        const numIdx = phrase.indexOf(numMatch[0]);
        
        // Simple name split
        let itemQuery = '';
        let unitText = 'units';
        
        const left = phrase.substring(0, numIdx).trim();
        const right = phrase.substring(numIdx + numMatch[0].length).trim();
        
        // Determine name
        if (!left || ['i have', 'we have', 'set', 'update', 'add'].includes(left)) {
          // E.g., "5 bags of rice"
          const rightClean = right.replace(/^of\s+/, '').trim();
          const words = rightClean.split(' ');
          if (words.length > 1 && ['bags', 'kg', 'boxes', 'packets', 'blocks'].includes(words[0])) {
            unitText = words[0];
            itemQuery = words.slice(1).join(' ');
          } else {
            itemQuery = rightClean;
          }
        } else {
          // E.g., "rice 5 bags"
          itemQuery = left.replace(/^(set|update|add|change)\s+/, '').replace(/\s+to$/, '');
          const words = right.split(' ');
          if (words.length > 0) {
            unitText = words[0];
          }
        }

        itemQuery = itemQuery.trim();
        if (!itemQuery) return;

        // Find match in local list
        let bestMatch = null;
        let highestScore = 0;
        
        localIngredients.forEach(ing => {
          const nameLower = ing.item_name.toLowerCase();
          let score = 0;
          if (nameLower === itemQuery) {
            score = 100;
          } else if (nameLower.includes(itemQuery) || itemQuery.includes(nameLower)) {
            score = 70;
          }
          
          if (score > highestScore) {
            highestScore = score;
            bestMatch = ing;
          }
        });

        if (bestMatch && highestScore >= 70) {
          const oldStock = bestMatch.current_stock;
          bestMatch.current_stock = qty;
          adjustments.push({
            item_name: bestMatch.item_name,
            old_stock: oldStock,
            new_stock: qty,
            unit: bestMatch.unit_type
          });
        }
      });

      return adjustments;
    }

  })();
</script>
