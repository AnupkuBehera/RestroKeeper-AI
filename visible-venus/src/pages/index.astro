        loginForm.classList.add('hidden');
      });

      // Submit Login
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('login-email').value.trim();
        const password = document.getElementById('login-password').value.trim();

        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/auth/login`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, password })
            });

            if (res.ok) {
              const data = await res.json();
              localStorage.setItem('rk_token', data.access_token);
              showToast('Authentication success');
              window.location.reload();
            } else {
              const err = await res.json();
              showToast(err.detail || 'Login failed. Incorrect details.', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('Connection error to auth API', 'error');
          }
        } else {
          // Offline Sandbox bypass token
          const dummyPayload = {
            sub: email,
            user_id: 1,
            tenant_id: 1,
            exp: Math.floor(Date.now() / 1000) + 86400
          };
          const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));
          const payload = btoa(JSON.stringify(dummyPayload));
          const signature = 'sandbox_sig';
          const token = `${header}.${payload}.${signature}`;
          
          localStorage.setItem('rk_token', token);
          showToast('[Sandbox] Bypassed auth via dummy JWT token');
          window.location.reload();
        }
      });

      // Submit Signup
      signupForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const restaurant_name = document.getElementById('signup-restaurant').value.trim();
        const name = document.getElementById('signup-name').value.trim();
        const email = document.getElementById('signup-email').value.trim();
        const password = document.getElementById('signup-password').value.trim();

        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/auth/signup`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, email, password, restaurant_name })
            });

            if (res.ok) {
              const data = await res.json();
              localStorage.setItem('rk_token', data.access_token);
              showToast('Tenant Profile created successfully');
              window.location.reload();
            } else {
              const err = await res.json();
              showToast(err.detail || 'Registration failed.', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('Connection error to registration API', 'error');
          }
        } else {
          // Offline Signup bypass
          const dummyPayload = {
            sub: email,
            user_id: 1,
            tenant_id: 1,
            exp: Math.floor(Date.now() / 1000) + 86400
          };
          const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));
          const payload = btoa(JSON.stringify(dummyPayload));
          const signature = 'sandbox_sig';
          const token = `${header}.${payload}.${signature}`;
          
          localStorage.setItem('rk_token', token);
          showToast('[Sandbox] Established profile locally');
          window.location.reload();
        }
      });
    }

  })();
</script>
