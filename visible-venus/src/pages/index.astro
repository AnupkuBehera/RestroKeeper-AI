    function renderInvoiceAuditData(data) {
      const emptyState = document.getElementById('invoice-empty-state');
      const loadingSkeleton = document.getElementById('invoice-loading-skeleton');
      const resultsPanel = document.getElementById('invoice-results-panel');
      const tbody = document.getElementById('invoice-items-tbody');

      loadingSkeleton.classList.add('hidden');
      emptyState.classList.add('hidden');
      resultsPanel.classList.remove('hidden');

      // Set headers
      document.getElementById('invoice-vendor-name').innerText = data.vendor_name;
      document.getElementById('invoice-doc-number').innerText = `#${data.invoice_number}`;
      document.getElementById('invoice-total-cost').innerText = `$${data.total_amount.toFixed(2)}`;

      tbody.innerHTML = '';
      let anomalyDetected = false;

      data.items.forEach(item => {
        let statusBadge = `<span class="px-2 py-0.5 rounded bg-emerald-950/50 text-emerald-500 border border-emerald-500/20 font-bold font-mono text-[10px]">Normal</span>`;
        let priceDiffMarkup = `<span class="text-charcoal-400 font-mono">$${item.previous_price ? item.previous_price.toFixed(2) : '-'}</span>`;

        if (item.price_anomaly) {
          anomalyDetected = true;
          const diffPct = item.previous_price ? Math.round(((item.unit_price - item.previous_price) / item.previous_price) * 100) : 0;
          statusBadge = `
            <div class="flex items-center gap-1 text-amber-500 bg-amber-950/50 border border-amber-500/20 px-2 py-0.5 rounded font-bold font-mono text-[10px] w-fit">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-9 9-4-4-6 6" />
              </svg>
              +${diffPct}% Increase
            </div>
          `;
          priceDiffMarkup = `<span class="text-rose-500 line-through font-mono">$${item.previous_price.toFixed(2)}</span>`;
        }

        tbody.innerHTML += `
          <tr class="hover:bg-charcoal-800/40">
            <td class="py-3 font-semibold text-charcoal-50">${item.item_name}</td>
            <td class="py-3 font-mono text-charcoal-200">${item.quantity}</td>
            <td class="py-3 font-mono text-charcoal-50 font-bold">$${item.unit_price.toFixed(2)}</td>
            <td class="py-3 font-mono">${priceDiffMarkup}</td>
            <td class="py-3">${statusBadge}</td>
