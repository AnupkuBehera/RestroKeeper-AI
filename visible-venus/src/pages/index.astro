      document.querySelectorAll('.send-po-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const vIdx = parseInt(btn.getAttribute('data-v-idx'));
          handleSendPurchaseOrder(vIdx);
        });
      });
    }

    function calculateLocalDraftPOs() {
      const vendor_groups_map = {};
      let critical_alerts = 0;
      let total_procurement_cost = 0.0;

      const package_units = {
        'bags': 5.0,
        'blocks': 2.0,
        'kg': 10.0,
        'boxes': 1.0
      };

      localIngredients.forEach(ing => {
        const forecasted_need = Math.round(ing.safety_par_level * 1.4 * 10) / 10;
        const isDeficit = ing.current_stock < ing.safety_par_level;
        
        if (isDeficit) {
          critical_alerts++;
        }

        if (isDeficit || (ing.current_stock < forecasted_need)) {
          const raw_needed = forecasted_need + ing.safety_par_level - ing.current_stock;
          if (raw_needed <= 0) return;

          const unitStr = ing.unit_type.toLowerCase();
          const pkgSize = package_units[unitStr] || 1.0;
          const recommended_qty = Math.ceil(raw_needed / pkgSize) * pkgSize;

          const total_cost = recommended_qty * ing.cost_per_unit;
          total_procurement_cost += total_cost;

          const draft = {
            item_name: ing.item_name,
            current_stock: ing.current_stock,
            safety_par_level: ing.safety_par_level,
            forecasted_demand: forecasted_need,
            recommended_order_qty: recommended_qty,
            unit: ing.unit_type,
            cost_per_unit: ing.cost_per_unit,
            total_cost: total_cost
          };

          const vendor = ing.vendor_name || 'Generic Supplier';
          if (!vendor_groups_map[vendor]) {
            vendor_groups_map[vendor] = [];
          }
          vendor_groups_map[vendor].push(draft);
        }
      });

      const draft_orders = [];
      Object.keys(vendor_groups_map).forEach(vendor => {
        const items = vendor_groups_map[vendor];
        const total_vendor_cost = items.reduce((sum, i) => sum + i.total_cost, 0);
        draft_orders.push({
          vendor_name: vendor,
          items: items,
          total_order_cost: total_vendor_cost
        });
      });

      return {
        draft_orders: draft_orders,
        critical_stock_alerts: critical_alerts,
        pending_purchase_orders_count: draft_orders.length,
        total_waste_saved_estimate: critical_alerts * 45.20
      };
    }

    // Modal Actions
    function openEditModal(vIdx, itemIdx) {
      const item = activePOData[vIdx].items[itemIdx];
      editingPOVendorName = activePOData[vIdx].vendor_name;
      editingPOItemIndex = itemIdx;

      document.getElementById('modal-item-name').value = item.item_name;
      document.getElementById('modal-item-qty').value = item.recommended_order_qty;
      document.getElementById('modal-item-unit').innerText = item.unit;

      document.getElementById('edit-modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('edit-modal').classList.add('hidden');
    }

    function saveModalItemChanges() {
      const newQty = parseFloat(document.getElementById('modal-item-qty').value);
      if (isNaN(newQty) || newQty < 0) {
        showToast('Invalid quantity value entered', 'error');
        return;
      }

      // Find inside local database list and alter recommended PO quantities
      const vendorGroup = activePOData.find(group => group.vendor_name === editingPOVendorName);
      if (vendorGroup) {
        const item = vendorGroup.items[editingPOItemIndex];
        
        // Update stock forecast cost
        item.recommended_order_qty = newQty;
        item.total_cost = newQty * item.cost_per_unit;

        // Recalculate totals
        vendorGroup.total_order_cost = vendorGroup.items.reduce((sum, i) => sum + i.total_cost, 0);
        
        // Redraw page lists
        closeModal();
        showToast('Line item order quantity updated!');
        
        // Update stats
        const container = document.getElementById('vendor-panels-container');
        refreshProcurementDrafts();
      }
    }

    async function handleSendPurchaseOrder(vIdx) {
      const vendorName = activePOData[vIdx].vendor_name;
      const orderTotal = activePOData[vIdx].total_order_cost;
      const items = activePOData[vIdx].items;

      showToast(`Dispatching PO to ${vendorName}...`);

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/procurement/send-po`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Tenant-ID': '1'
            },
            body: JSON.stringify({
              vendor_name: vendorName,
              items: items,
              recipient_email: 'orders@vendor.com'
            })
          });

          if (res.ok) {
            const data = await res.json();
            showToast(`Purchase order approved & sent to ${vendorName} ($${orderTotal.toFixed(2)})!`);
          } else {
            throw new Error('PO Dispatch failed');
          }
        } catch (e) {
          console.error(e);
          showToast(`Offline notice: PO simulated for ${vendorName} ($${orderTotal.toFixed(2)})`, 'warning');
        }
      } else {
        showToast(`Purchase order approved & dispatched to ${vendorName} ($${orderTotal.toFixed(2)})!`);
      }
      
      // Animate slide-out panel deletion
      const panel = document.getElementById(`vendor-panel-${vIdx}`);
      panel.classList.add('transition-all', 'duration-500', 'transform', 'scale-95', 'opacity-0');
      
      setTimeout(() => {
        // Remove from local list of draft orders
        activePOData.splice(vIdx, 1);
        
        // Update remaining stats
        const pendingSpan = document.getElementById('stat-pending-orders');
        pendingSpan.innerText = activePOData.length;
        
        refreshProcurementDrafts();
      }, 500);
    }
  </script>
