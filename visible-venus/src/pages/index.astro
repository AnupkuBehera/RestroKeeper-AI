---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Authentication Overlay (Modal) -->
  <div id="auth-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-charcoal-950/80 backdrop-blur-md hidden">
    <div class="w-full max-w-md bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-2xl p-6 space-y-6">
      
      <!-- Logo inside modal -->
      <div class="flex items-center gap-3 justify-center mb-2">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500 text-charcoal-950 font-bold tracking-tight">
          RK
        </div>
        <span class="text-lg font-semibold tracking-tight text-charcoal-50">RestoKeeper <span class="text-emerald-500 font-bold">AI</span></span>
      </div>

      <!-- Tab selection (Login vs Signup) -->
      <div class="flex border-b border-charcoal-700 pb-2 gap-4 text-sm font-mono justify-center">
        <button id="auth-login-tab" class="text-emerald-500 font-bold border-b-2 border-emerald-500 pb-1">Log In</button>
        <button id="auth-signup-tab" class="text-charcoal-400 hover:text-charcoal-100 pb-1">Create Account</button>
      </div>

      <!-- Login Form -->
      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Email Address</label>
          <input type="email" id="login-email" required placeholder="manager@bistro.com" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Password</label>
          <input type="password" id="login-password" required placeholder="••••••••" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-3 rounded-xl transition-all shadow-md">
          Authenticate Manager
        </button>
      </form>

      <!-- Signup Form -->
      <form id="signup-form" class="space-y-4 hidden">
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Restaurant Name</label>
          <input type="text" id="signup-restaurant" required placeholder="RestoKeeper Bistro" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Manager Name</label>
          <input type="text" id="signup-name" required placeholder="Chef John Doe" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Email Address</label>
          <input type="email" id="signup-email" required placeholder="chef@bistro.com" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Password</label>
          <input type="password" id="signup-password" required placeholder="Min 6 characters" minlength="6" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
        </div>
        <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-3 rounded-xl transition-all shadow-md">
          Establish Tenant Profile
        </button>
      </form>
    </div>
  </div>

  <!-- Header Navbar -->
  <header class="sticky top-0 z-40 border-b border-charcoal-700 bg-charcoal-900/85 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500 text-charcoal-950 font-bold tracking-tight">
          RK
        </div>
        <div>
          <span class="text-lg font-semibold tracking-tight text-charcoal-50">RestoKeeper <span class="text-emerald-500 font-bold">AI</span></span>
          <span class="block text-[10px] text-charcoal-400 font-mono tracking-wider uppercase" id="nav-subtitle">SaaS Inventory Platform</span>
        </div>
      </div>

      <!-- Server & Sheets Status Badge -->
      <div class="flex items-center gap-3">
        <div id="backend-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs">
          <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse" id="backend-dot"></span>
          <span class="text-charcoal-400 font-mono text-[11px]" id="backend-text">Checking API...</span>
        </div>
        <div id="sheets-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs cursor-pointer hover:border-charcoal-600 transition-all">
          <svg class="h-3.5 w-3.5 text-charcoal-400" id="sheets-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-charcoal-400 font-mono text-[11px]" id="sheets-text">Sheets: Sandbox</span>
        </div>
        <button id="logout-btn" class="hidden rounded-md border border-charcoal-700 hover:border-charcoal-600 bg-charcoal-900 px-3 py-1.5 text-xs text-rose-500 hover:text-rose-400 font-medium transition-all">
          Log Out
        </button>
      </div>
    </div>
  </header>

  <!-- Google Sheet Sync Status Drawer -->
  <div id="sheets-info-drawer" class="hidden mx-auto max-w-7xl px-4 mt-4 sm:px-6 lg:px-8">
    <div class="bg-charcoal-800 border border-charcoal-700 rounded-xl p-4 text-xs font-mono text-charcoal-300 space-y-2.5 shadow-2xl">
      <div class="flex justify-between items-center text-charcoal-200 border-b border-charcoal-700 pb-2">
        <span class="font-bold uppercase text-[10px] tracking-wider text-emerald-500 flex items-center gap-1">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Google Sheets Sync status
        </span>
        <button id="close-sheets-drawer" class="text-charcoal-400 hover:text-charcoal-200 cursor-pointer">✕ Close</button>
      </div>
      <p>
        1. Share your Google Sheet with edit access to this Service Account email:
        <code class="bg-charcoal-900 text-emerald-400 px-2 py-1 rounded block mt-1 select-all select-text font-semibold font-mono" id="sheets-email-display">gcp-service-account@not-configured.iam.gserviceaccount.com</code>
      </p>
      <div class="pt-2 border-t border-charcoal-700/50 flex items-center justify-between">
        <span>Spreadsheet: <strong id="sheets-drawer-status" class="text-amber-500 font-semibold font-mono">Sandbox Simulation (Offline Cache)</strong></span>
        <a href="#" id="sheets-link-url" target="_blank" class="hidden text-emerald-500 hover:text-emerald-400 underline font-bold flex items-center gap-1 transition-all">
          Open Spreadsheet 🔗
        </a>
      </div>
    </div>
  </div>

  <!-- Main Container -->
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 space-y-6">

    <!-- Nav tabs -->
    <div class="flex border-b border-charcoal-700 gap-2 font-mono text-xs overflow-x-auto pb-px" id="nav-tabs">
      <button class="tab-btn active-tab px-4 py-2.5 rounded-t-lg bg-charcoal-800 text-emerald-500 border-t border-x border-charcoal-700 font-bold transition-all" data-tab="tab-stock">
        📦 Stock Control
      </button>
      <button class="tab-btn px-4 py-2.5 rounded-t-lg text-charcoal-400 hover:text-charcoal-100 transition-all" data-tab="tab-recipes">
        📜 Menu Recipes & POS
      </button>
      <button class="tab-btn px-4 py-2.5 rounded-t-lg text-charcoal-400 hover:text-charcoal-100 transition-all" data-tab="tab-batches">
        ⏳ Batches & Wastage
      </button>
    </div>

    <!-- TAB 1: STOCK CONTROL SECTION -->
    <div id="tab-stock" class="tab-content grid grid-cols-1 lg:grid-cols-12 gap-6">
      
      <!-- Left Column: Spoken / Typed Counts -->
      <section class="lg:col-span-5 space-y-6">
        <!-- Low Stock warning Alerts Box -->
        <div id="restock-alerts-container" class="hidden rounded-xl border border-rose-500/30 bg-rose-950/15 p-4 shadow-md">
          <div class="flex items-start gap-3">
            <span class="text-rose-500 flex-shrink-0 animate-pulse text-lg">⚠️</span>
            <div class="flex-1">
              <h4 class="text-xs font-bold text-rose-500 font-mono tracking-wider uppercase">LOW STOCK REMINDERS</h4>
              <ul id="restock-alerts-list" class="mt-2.5 space-y-1 text-xs font-mono">
                <!-- Dynamically populated low stock alerts -->
              </ul>
            </div>
          </div>
        </div>

        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Voice & Type Auditor</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Quick update quantities by speaking or typing</p>
          </div>

          <div class="p-6 flex flex-col items-center">
            
            <!-- Speech Recognition Mic Button -->
            <div class="relative my-4 flex flex-col items-center justify-center">
              <button id="mic-record-btn" class="h-28 w-28 rounded-full bg-charcoal-700 border-4 border-charcoal-600 flex items-center justify-center text-charcoal-50 hover:text-emerald-500 transition-all shadow-lg hover:scale-105 active:scale-95 cursor-pointer z-10">
                <svg id="mic-icon" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                </svg>
              </button>
              <div id="mic-pulse-ring" class="hidden absolute top-0 left-0 h-28 w-28 rounded-full border border-emerald-500/50 animate-mic-pulse"></div>
              
              <span id="mic-status-label" class="mt-4 text-xs font-semibold text-charcoal-400 font-mono tracking-wider">TAP TO VOICE COUNT</span>
            </div>

            <!-- Voice Ticker -->
            <div id="voice-ticker" class="w-full text-center text-xs font-mono italic text-emerald-400 min-h-[20px] mb-4">
              Standing by... Speak your counts or type below.
            </div>

            <!-- Text Box Input -->
            <div class="w-full space-y-2">
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider">Spoken / Typed Counts</label>
              <textarea id="inventory-text-input" placeholder='e.g., Atta 5 bags, Dal 12 kg, Rice 10 bags' rows="3" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-xl p-3 text-sm text-charcoal-50 focus:outline-none focus:border-emerald-500 font-mono"></textarea>
              <button id="process-stock-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-sm py-2.5 rounded-xl transition-all shadow-md">
                Update Stock counts & Sync
              </button>
            </div>

            <!-- Synced Stock adjustments feedback -->
            <div id="sync-results" class="w-full mt-4 hidden">
              <div class="rounded-xl border border-emerald-500/20 bg-emerald-950/10 p-4">
                <span class="text-[10px] font-bold text-emerald-500 font-mono uppercase block mb-2">Synced Stock Adjustments:</span>
                <ul class="space-y-1.5 text-xs font-mono" id="updated-stock-list">
                  <!-- Synced updates -->
                </ul>
              </div>
            </div>

            <!-- Simulation Count Shortcuts -->
            <div class="w-full border-t border-charcoal-700 pt-4 mt-6">
              <span class="text-[10px] font-semibold text-charcoal-400 font-mono tracking-wider block mb-2 uppercase">Quick Simulation Shortcuts:</span>
              <div class="flex flex-col gap-1.5">
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Dal 12 kg, Atta 8 bags">
                  <span>"Dal 12 kg, Atta 8 bags"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Fill Atta & Dal</span>
                </button>
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Rice 10 bags, Potato 25 kg">
                  <span>"Rice 10 bags, Potato 25 kg"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Increase Rice & Potato</span>
                </button>
                <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Sugar 8 kg">
                  <span>"Sugar 8 kg"</span>
                  <span class="text-[9px] bg-emerald-950 text-emerald-500 border border-emerald-500/20 rounded px-1.5 font-mono">Replenish Sugar</span>
                </button>
              </div>
            </div>

          </div>
        </div>

        <!-- Add Custom Ingredient SKU Form -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4 flex justify-between items-center">
            <h2 class="text-base font-semibold text-charcoal-50">Register New Ingredient SKU</h2>
            <button id="toggle-add-form" class="text-xs text-emerald-500 font-bold hover:underline">Toggle Form</button>
          </div>

          <div id="add-ing-form" class="p-6 space-y-3.5 hidden">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Item Name</label>
              <input type="text" id="new-ing-name" placeholder="e.g. Garlic" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
            </div>
            <div class="grid grid-cols-2 gap-2.5">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">SKU Code</label>
                <input type="text" id="new-ing-sku" placeholder="SKU-GAR-07" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Unit Type</label>
                <input type="text" id="new-ing-unit" placeholder="kg, bags, boxes" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-2.5">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Safety Par Level</label>
                <input type="number" id="new-ing-par" placeholder="10" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Cost / Unit ($)</label>
                <input type="number" id="new-ing-cost" placeholder="3.50" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Supplier Name</label>
              <input type="text" id="new-ing-vendor" placeholder="Fresh Produce Co." class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
            </div>
            <button id="save-new-ing-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
              Save Ingredient SKU & Sync
            </button>
          </div>
        </div>
      </section>

      <!-- Right Column: Stock Inventory Table -->
      <section class="lg:col-span-7">
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
              <h2 class="text-base font-semibold text-charcoal-50">Master Ingredient Inventory</h2>
              <p class="text-xs text-charcoal-400 mt-0.5">Directly edit quantities in the table to synchronize instantly</p>
            </div>
            <div class="flex items-center gap-2">
              <button id="demo-reset-btn-v1" class="rounded-md border border-charcoal-700 hover:border-charcoal-600 bg-charcoal-900 px-3 py-1.5 text-xs text-charcoal-200 transition-all">
                Reset Stock levels
              </button>
              <button id="clear-stocks-btn" class="rounded-md border border-rose-500/30 hover:bg-rose-950/20 bg-charcoal-900 px-3 py-1.5 text-xs text-rose-500 font-medium transition-all" title="Clear all stock levels to 0.0 for fresh count">
                🗑️ Clear Stocks
              </button>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-xs font-mono">
              <thead>
                <tr class="border-b border-charcoal-700 bg-charcoal-900/40 text-charcoal-400 text-[10px] tracking-wider uppercase">
                  <th class="p-4 font-semibold">SKU / Item</th>
                  <th class="p-4 font-semibold text-center">Current Stock</th>
                  <th class="p-4 font-semibold text-center">Par Level</th>
                  <th class="p-4 font-semibold">Cost & Supplier</th>
                  <th class="p-4 font-semibold text-center">Status</th>
                  <th class="p-4 font-semibold text-center">Action</th>
                </tr>
              </thead>
              <tbody id="inventory-table-tbody" class="divide-y divide-charcoal-700/50">
                <!-- Dynamically populated inventory rows -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

    </div>

    <!-- TAB 2: MENU RECIPES & POS SIMULATION SECTION -->
    <div id="tab-recipes" class="tab-content hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
      
      <!-- Left Column: Add Menu Item / Recipe Mapping Form -->
      <section class="lg:col-span-5 space-y-6">
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Create Menu Item & Recipe</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Map selling items to raw ingredients</p>
          </div>

          <form id="create-menu-form" class="p-6 space-y-4">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Menu Item Name</label>
              <input type="text" id="menu-name" required placeholder="e.g. Roti, Dal Fry" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
            </div>
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Selling Price ($)</label>
              <input type="number" step="0.01" id="menu-price" required placeholder="e.g. 5.50" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
            </div>

            <!-- Dynamic Recipe Ingredients lines -->
            <div class="space-y-2">
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider">Recipe Ingredients</label>
              <div id="recipe-ingredients-list" class="space-y-2">
                <!-- Row template will append here -->
              </div>
              <button type="button" id="add-recipe-row-btn" class="w-full rounded border border-charcoal-700 bg-charcoal-900 text-charcoal-200 hover:text-emerald-500 py-1.5 text-xs font-mono transition-all">
                ➕ Add Ingredient Requirement
              </button>
            </div>

            <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
              Save Menu Item Recipe
            </button>
          </form>
        </div>
      </section>

      <!-- Right Column: Menu Items & POS Simulator -->
      <section class="lg:col-span-7 space-y-6">
        
        <!-- POS Sales Simulator -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden p-6 space-y-4">
          <div class="border-b border-charcoal-700 pb-3 flex justify-between items-center">
            <div>
              <h3 class="text-sm font-bold text-charcoal-50 font-mono uppercase tracking-wider">POS Terminal Simulator</h3>
              <p class="text-xs text-charcoal-400">Deduct raw stocks dynamically based on dishes sold</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Select Menu Item</label>
              <select id="pos-menu-select" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none">
                <!-- Options populated dynamically -->
              </select>
            </div>
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Quantity Sold</label>
              <input type="number" id="pos-qty" min="1" value="1" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none" />
            </div>
          </div>
          <button id="pos-simulate-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
            Execute POS Sale & Deduct FIFO Batches
          </button>
        </div>

        <!-- Menu list Table -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Active Menu & Recipe Specifications</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-xs font-mono">
              <thead>
                <tr class="border-b border-charcoal-700 bg-charcoal-900/40 text-charcoal-400 text-[10px] tracking-wider uppercase">
                  <th class="p-4 font-semibold">Menu Dish</th>
                  <th class="p-4 font-semibold">Price</th>
                  <th class="p-4 font-semibold">Ingredients Required</th>
                </tr>
              </thead>
              <tbody id="menu-table-tbody" class="divide-y divide-charcoal-700/50">
                <!-- Dynamically populated menu rows -->
              </tbody>
            </table>
          </div>
        </div>

      </section>
    </div>

    <!-- TAB 3: BATCHES, WASTAGE, & EXPIRY ALERTS -->
    <div id="tab-batches" class="tab-content hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
      
      <!-- Left Column: Log Batch / Log Wastage Forms -->
      <section class="lg:col-span-5 space-y-6">
        
        <!-- Log New Stock Batch -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Receive New Stock Batch</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Logs ingredient quantities with expiration limits</p>
          </div>

          <form id="receive-batch-form" class="p-6 space-y-4">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Select Ingredient</label>
              <select id="batch-ingredient-select" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none">
                <!-- Options populated dynamically -->
              </select>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Batch Qty</label>
                <input type="number" step="0.1" id="batch-qty" required class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Expiry Date</label>
                <input type="date" id="batch-expiry" required class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50" />
              </div>
            </div>
            <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
              Receive & Log Batch
            </button>
          </form>
        </div>

        <!-- Log Stock Wastage -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Log Stock Wastage</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Remove spoiled/wasted ingredients via FIFO</p>
          </div>

          <form id="log-wastage-form" class="p-6 space-y-4">
            <div>
              <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Select Ingredient</label>
              <select id="wastage-ingredient-select" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none">
                <!-- Options populated dynamically -->
              </select>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Wasted Qty</label>
                <input type="number" step="0.1" id="wastage-qty" required class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50" />
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Reason</label>
                <input type="text" id="wastage-reason" placeholder="Spoiled, Spilled" class="w-full bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50" />
              </div>
            </div>
            <button type="submit" class="w-full bg-rose-600 hover:bg-rose-700 text-charcoal-50 font-bold text-xs py-2.5 rounded-lg transition-all shadow-md">
              Log Wastage & Deduct Stock
            </button>
          </form>
        </div>

      </section>

      <!-- Right Column: Expiry Alerts and Batches Table -->
      <section class="lg:col-span-7 space-y-6">
        
        <!-- Expiry Alerts panel -->
        <div id="expiry-alerts-card" class="hidden bg-charcoal-800 border border-amber-500/30 rounded-2xl shadow-xl overflow-hidden p-6 space-y-3">
          <div class="flex items-center gap-2 text-amber-500 font-mono font-bold text-xs">
            <span>⏳ EXPIRING BATCH ALERTS (Next 7 Days)</span>
          </div>
          <ul id="expiry-alerts-list" class="space-y-1.5 text-xs font-mono">
            <!-- Expiring lists -->
          </ul>
        </div>

        <!-- Stock batches list Table -->
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
          <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-4">
            <h2 class="text-base font-semibold text-charcoal-50">Active Ingredient Batches</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-xs font-mono">
              <thead>
                <tr class="border-b border-charcoal-700 bg-charcoal-900/40 text-charcoal-400 text-[10px] tracking-wider uppercase">
                  <th class="p-4 font-semibold">Ingredient</th>
                  <th class="p-4 font-semibold text-center">Batch Quantity</th>
                  <th class="p-4 font-semibold text-center">Received Date</th>
                  <th class="p-4 font-semibold text-center">Expiry Date</th>
                </tr>
              </thead>
              <tbody id="batches-table-tbody" class="divide-y divide-charcoal-700/50">
                <!-- Dynamically populated batch rows -->
              </tbody>
            </table>
          </div>
        </div>

      </section>
    </div>

  </main>

  <!-- Simple Toast Notifications -->
  <div id="toast" class="fixed bottom-4 right-4 z-50 transform translate-y-10 opacity-0 bg-charcoal-800 border border-charcoal-700 text-charcoal-50 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300">
    <span id="toast-message">Stock levels updated.</span>
  </div>
</Layout>

<script is:inline>
  (function () {
    const BACKEND_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' 
      ? 'http://localhost:8000' 
      : window.location.origin;
    let isBackendOnline = false;
    let localIngredients = [];
    let localMenuItems = [];
    let localBatches = [];

    // Initialize application
    document.addEventListener('DOMContentLoaded', async () => {
      checkSessionToken();
      await checkBackendHealth();
      await fetchSheetsConfig();
      await refreshData();
      
      initNavigation();
      initSpeechRecognition();
      setupEventListeners();
      setupAuthFormListeners();
    });

    // Dynamic headers based on local JWT storage
    function getHeaders() {
      const headers = {
        'X-Tenant-ID': '1'
      };
      const token = localStorage.getItem('rk_token');
      if (token) {
        headers['Authorization'] = `Bearer ${token}`;
      }
      return headers;
    }

    // Check token
    function checkSessionToken() {
      const token = localStorage.getItem('rk_token');
      const modal = document.getElementById('auth-modal');
      const logoutBtn = document.getElementById('logout-btn');
      
      if (!token) {
        modal.classList.remove('hidden');
        logoutBtn.classList.add('hidden');
      } else {
        modal.classList.add('hidden');
        logoutBtn.classList.remove('hidden');
        
        // Try decoding to set sub title restaurant/user
        try {
          const payload = JSON.parse(atob(token.split('.')[1]));
          document.getElementById('nav-subtitle').innerText = `Chef: ${payload.sub}`;
        } catch (e) {
          console.error(e);
        }
      }
    }

    // Refresh all tables
    async function refreshData() {
      await fetchIngredients();
      await fetchMenuItems();
      await fetchBatches();
      await fetchExpiryAlerts();
    }

    // Toast Alert Helper
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-message');
      toastMsg.innerText = message;
      
      if (type === 'error') {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-rose-950 border border-rose-500/30 text-rose-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      } else if (type === 'warning') {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-amber-955 border border-amber-500/30 text-amber-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      } else {
        toast.className = 'fixed bottom-4 right-4 z-50 bg-charcoal-800 border border-emerald-500/30 text-emerald-400 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300 transform translate-y-0 opacity-100';
      }

      setTimeout(() => {
        toast.className = 'fixed bottom-4 right-4 z-50 transform translate-y-10 opacity-0 bg-charcoal-800 border border-charcoal-700 text-charcoal-50 px-4 py-2.5 rounded-lg text-xs font-mono shadow-2xl flex items-center gap-2 transition-all duration-300';
      }, 3500);
    }

    // Health check endpoint
    async function checkBackendHealth() {
      const dot = document.getElementById('backend-dot');
      const text = document.getElementById('backend-text');
      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/health`);
        if (res.ok) {
          isBackendOnline = true;
          dot.className = 'h-2 w-2 rounded-full bg-emerald-500';
          text.innerText = 'API: Connected';
        } else {
          throw new Error('API offline');
        }
      } catch (e) {
        isBackendOnline = false;
        dot.className = 'h-2 w-2 rounded-full bg-rose-500 animate-pulse';
        text.innerText = 'API: Sandbox';
        showToast('Running in Sandbox Mode (Offline Cache)', 'warning');
      }
    }

    // Sheets config loader
    async function fetchSheetsConfig() {
      const badge = document.getElementById('sheets-text');
      const icon = document.getElementById('sheets-icon');
      const drawerStatus = document.getElementById('sheets-drawer-status');
      const emailDisplay = document.getElementById('sheets-email-display');
      const linkUrl = document.getElementById('sheets-link-url');

      if (!isBackendOnline) {
        badge.innerText = 'Sheets: Sandbox';
        badge.className = 'text-charcoal-400 font-mono text-[11px]';
        drawerStatus.innerText = 'Sandbox Simulation (Offline Cache)';
        drawerStatus.className = 'text-amber-500 font-semibold font-mono';
        return;
      }

      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/sheets/config`, {
          headers: getHeaders()
        });
        if (res.ok) {
          const config = await res.json();
          if (config.is_mock) {
            badge.innerText = 'Sheets: Sandbox';
            badge.className = 'text-charcoal-400 font-mono text-[11px]';
            drawerStatus.innerText = 'Sandbox Simulation (Offline Cache)';
            drawerStatus.className = 'text-amber-500 font-semibold';
            linkUrl.classList.add('hidden');
          } else {
            badge.innerText = 'Sheets: Linked';
            badge.className = 'text-emerald-500 font-mono text-[11px]';
            icon.setAttribute('class', 'h-3.5 w-3.5 text-emerald-500');
            drawerStatus.innerText = 'Linked & Synchronizing';
            drawerStatus.className = 'text-emerald-500 font-semibold';
            emailDisplay.innerText = config.share_email;
            linkUrl.href = `https://docs.google.com/spreadsheets/d/${config.sheet_id}`;
            linkUrl.classList.remove('hidden');
          }
        }
      } catch (e) {
        console.error(e);
      }
    }

    // Get ingredients
    async function fetchIngredients() {
      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients`, {
            headers: getHeaders()
          });
          if (res.ok) {
            localIngredients = await res.json();
          }
        } catch (e) {
          console.error('Failed to fetch backend ingredients', e);
        }
      }
      renderInventory();
      populateDropdowns();
    }

    // Populate dropdown selectors
    function populateDropdowns() {
      const batchSelect = document.getElementById('batch-ingredient-select');
      const wastageSelect = document.getElementById('wastage-ingredient-select');
      
      batchSelect.innerHTML = '';
      wastageSelect.innerHTML = '';

      localIngredients.forEach(ing => {
        const optionHTML = `<option value="${ing.id}">${ing.item_name} (${ing.unit_type})</option>`;
        batchSelect.innerHTML += optionHTML;
        wastageSelect.innerHTML += optionHTML;
      });

      // Update recipe ingredient dropdowns in Tab 2 if there's any active rows
      document.querySelectorAll('.recipe-ing-dropdown').forEach(select => {
        const currentVal = select.value;
        select.innerHTML = '';
        localIngredients.forEach(ing => {
          select.innerHTML += `<option value="${ing.id}">${ing.item_name}</option>`;
        });
        if (currentVal) select.value = currentVal;
      });
    }

    // Render alerts & table rows
    function renderInventory() {
      const alertsList = document.getElementById('restock-alerts-list');
      const alertsContainer = document.getElementById('restock-alerts-container');
      const tbody = document.getElementById('inventory-table-tbody');
      
      alertsList.innerHTML = '';
      tbody.innerHTML = '';

      let lowStockItemsCount = 0;

      localIngredients.forEach(ing => {
        const isLow = ing.current_stock < ing.safety_par_level;
        
        if (isLow) {
          lowStockItemsCount++;
          alertsList.innerHTML += `
            <li class="flex items-center justify-between text-rose-400">
              <span>➔ <strong>${ing.item_name}</strong> is low</span>
              <span>(${ing.current_stock}/${ing.safety_par_level} ${ing.unit_type})</span>
            </li>
          `;
        }

        const rowClass = isLow ? 'bg-amber-955/5 border-l-2 border-l-amber-500/40 hover:bg-amber-955/10' : 'hover:bg-charcoal-700/30';
        const badgeClass = isLow ? 'bg-rose-955 border border-rose-500/30 text-rose-500 animate-pulse' : 'bg-emerald-955 border border-emerald-500/30 text-emerald-500';
        const badgeText = isLow ? 'LOW STOCK' : 'NORMAL';

        tbody.innerHTML += `
          <tr class="${rowClass} transition-colors border-b border-charcoal-700/40">
            <td class="p-4">
              <span class="font-bold text-charcoal-50 block">${ing.item_name}</span>
              <span class="text-[10px] text-charcoal-400 font-mono">${ing.SKU_code}</span>
            </td>
            <td class="p-4 text-center">
              <div class="flex items-center justify-center gap-1.5">
                <input type="number" step="0.1" value="${ing.current_stock}" 
                  class="stock-inline-input w-16 bg-charcoal-900 border border-charcoal-700 rounded px-1.5 py-1 text-center font-bold text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" 
                  data-id="${ing.id}" data-sku="${ing.SKU_code}" />
                <span class="text-charcoal-400 text-[10px] font-mono select-none">${ing.unit_type}</span>
              </div>
            </td>
            <td class="p-4 text-center text-charcoal-200">
              ${ing.safety_par_level} <span class="text-charcoal-400 text-[10px]">${ing.unit_type}</span>
            </td>
            <td class="p-4 text-charcoal-300">
              <span class="block text-xs font-semibold">$${ing.cost_per_unit.toFixed(2)} / unit</span>
              <span class="text-[10px] text-charcoal-400 truncate max-w-[120px] block">${ing.vendor_name}</span>
            </td>
            <td class="p-4 text-center">
              <span class="inline-block px-2.5 py-0.5 rounded text-[9px] font-bold tracking-wider ${badgeClass}">
                ${badgeText}
              </span>
            </td>
            <td class="p-4 text-center">
              <button class="save-inline-btn bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 rounded p-1.5 font-bold transition-all" 
                data-id="${ing.id}" title="Save inline stock level">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            </td>
          </tr>
        `;
      });

      if (lowStockItemsCount > 0) {
        alertsContainer.classList.remove('hidden');
      } else {
        alertsContainer.classList.add('hidden');
      }

      // Inline save buttons
      document.querySelectorAll('.save-inline-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const id = parseInt(btn.getAttribute('data-id'));
          const input = document.querySelector(`.stock-inline-input[data-id="${id}"]`);
          if (input) {
            const stock = parseFloat(input.value);
            if (!isNaN(stock)) {
              await updateSingleStock(id, stock);
            }
          }
        });
      });
    }

    // Save individual stock update
    async function updateSingleStock(id, stock) {
      const item = localIngredients.find(i => i.id === id);
      if (!item) return;

      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/${id}`, {
            method: 'PUT',
            headers: getHeaders(),
            body: JSON.stringify({ current_stock: stock })
          });
          if (res.ok) {
            const updated = await res.json();
            item.current_stock = updated.current_stock;
            showToast(`Updated ${item.item_name} stock to ${stock}`);
            await refreshData();
          } else {
            showToast('Failed to sync stock updates', 'error');
          }
        } catch (e) {
          console.error(e);
          showToast('Connection error updating stock', 'error');
        }
      } else {
        item.current_stock = stock;
        showToast(`[Sandbox] Set ${item.item_name} stock to ${stock}`);
        renderInventory();
      }
    }

    // Speech-to-text setup
    function initSpeechRecognition() {
      const recordBtn = document.getElementById('mic-record-btn');
      const micPulseRing = document.getElementById('mic-pulse-ring');
      const micStatusLabel = document.getElementById('mic-status-label');
      const voiceTicker = document.getElementById('voice-ticker');
      const textArea = document.getElementById('inventory-text-input');

      let recognition = null;
      let isRecording = false;

      if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.continuous = false;
        recognition.interimResults = true;
        recognition.lang = 'en-US';

        recognition.onstart = () => {
          isRecording = true;
          recordBtn.classList.remove('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
          recordBtn.classList.add('bg-rose-500', 'border-rose-600', 'text-charcoal-950');
          micPulseRing.classList.remove('hidden');
          micStatusLabel.innerText = 'LISTENING...';
          micStatusLabel.className = 'mt-4 text-xs font-bold text-rose-500 font-mono tracking-wider animate-pulse';
          voiceTicker.innerText = 'Listening to speech... Speak counts (e.g. "Dal 12 kg and Atta 8 bags").';
        };

        recognition.onresult = (event) => {
          let interimTranscript = '';
          let finalTranscript = '';
          for (let i = event.resultIndex; i < event.results.length; ++i) {
            if (event.results[i].isFinal) {
              finalTranscript += event.results[i][0].transcript;
            } else {
              interimTranscript += event.results[i][0].transcript;
            }
          }
          const textToShow = finalTranscript || interimTranscript;
          voiceTicker.innerText = `"${textToShow}"`;
          if (finalTranscript) {
            textArea.value = finalTranscript;
          }
        };

        recognition.onerror = (event) => {
          console.error('Speech recognition error:', event.error);
          voiceTicker.innerText = `Speech error: ${event.error}. Please type.`;
        };

        recognition.onend = () => {
          isRecording = false;
          recordBtn.classList.add('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
          recordBtn.classList.remove('bg-rose-500', 'border-rose-600', 'text-charcoal-950');
          micPulseRing.classList.add('hidden');
          micStatusLabel.innerText = 'TAP TO VOICE COUNT';
          micStatusLabel.className = 'mt-4 text-xs font-semibold text-charcoal-400 font-mono tracking-wider';
          if (!textArea.value.trim()) {
            voiceTicker.innerText = 'Speech finished. Input field empty.';
          } else {
            voiceTicker.innerText = 'Speech transcribed! Review or edit text below.';
          }
        };

        recordBtn.addEventListener('click', () => {
          if (isRecording) {
            recognition.stop();
          } else {
            textArea.value = '';
            recognition.start();
          }
        });
      } else {
        recordBtn.addEventListener('click', () => {
          showToast('Voice Recognition is not supported by your browser. Please type instead.', 'warning');
          voiceTicker.innerText = 'Web Speech recognition not supported. Please type instead.';
        });
      }
    }

    // Toggle Tab Panels
    function initNavigation() {
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const tabId = btn.getAttribute('data-tab');
          
          // Switch tabs
          document.querySelectorAll('.tab-btn').forEach(b => {
            b.className = "tab-btn px-4 py-2.5 rounded-t-lg text-charcoal-400 hover:text-charcoal-100 transition-all";
          });
          btn.className = "tab-btn active-tab px-4 py-2.5 rounded-t-lg bg-charcoal-800 text-emerald-500 border-t border-x border-charcoal-700 font-bold transition-all";

          // Show contents
          document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.add('hidden');
          });
          document.getElementById(tabId).classList.remove('hidden');
        });
      });
    }

    // Recipe Ingredients Line row manager
    let recipeRowsCounter = 0;
    function addRecipeRequirementRow(ingId = '', qty = '') {
      const container = document.getElementById('recipe-ingredients-list');
      const rowId = `recipe-row-${recipeRowsCounter++}`;
      
      let dropdownOptions = '';
      localIngredients.forEach(ing => {
        const selected = ing.id == ingId ? 'selected' : '';
        dropdownOptions += `<option value="${ing.id}" ${selected}>${ing.item_name} (${ing.unit_type})</option>`;
      });

      container.insertAdjacentHTML('beforeend', `
        <div class="flex gap-2 items-center" id="${rowId}">
          <select class="recipe-ing-dropdown flex-1 bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50 focus:outline-none">
            ${dropdownOptions}
          </select>
          <input type="number" step="0.01" value="${qty}" required placeholder="Qty required" class="recipe-qty-input w-24 bg-charcoal-900 border border-charcoal-700 rounded-lg p-2 text-xs text-charcoal-50" />
          <button type="button" class="remove-recipe-row-btn text-rose-500 font-bold text-xs p-2 hover:underline" data-row-id="${rowId}">✕</button>
        </div>
      `);

      // Row remover listener
      document.querySelector(`button[data-row-id="${rowId}"]`).addEventListener('click', () => {
        document.getElementById(rowId).remove();
      });
    }

    // Fetch and render Menu Items & Recipes
    async function fetchMenuItems() {
      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/menu`, {
            headers: getHeaders()
          });
          if (res.ok) {
            localMenuItems = await res.json();
          }
        } catch (e) {
          console.error(e);
        }
      }
      renderMenuItems();
    }

    function renderMenuItems() {
      const tbody = document.getElementById('menu-table-tbody');
      const select = document.getElementById('pos-menu-select');
      
      tbody.innerHTML = '';
      select.innerHTML = '';

      if (localMenuItems.length === 0) {
