              </button>
            </div>
          </div>
        `;
      });

      // Bind button events inside dynamically injected elements
      document.querySelectorAll('.edit-item-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const vIdx = parseInt(btn.getAttribute('data-v-idx'));
