---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Navigation Header -->
  <header class="sticky top-0 z-40 border-b border-charcoal-700 bg-charcoal-900/85 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500 text-charcoal-950 font-bold tracking-tight">
          RK
        </div>
        <div>
          <span class="text-lg font-semibold tracking-tight text-charcoal-50">RestoKeeper <span class="text-emerald-500 font-bold">AI</span></span>
          <span class="block text-[10px] text-charcoal-400 font-mono tracking-wider uppercase">Procurement Engine</span>
        </div>
      </div>

      <!-- Navigation Tabs -->
      <nav class="hidden md:flex space-x-1" aria-label="Tabs">
        <button id="tab-btn-voice" class="nav-tab active-tab px-4 py-2 text-sm font-medium rounded-full transition-all">
          Voice Inventory
        </button>
        <button id="tab-btn-invoice" class="nav-tab px-4 py-2 text-sm font-medium rounded-full text-charcoal-400 hover:text-charcoal-50 transition-all">
          Invoice Auditor
        </button>
        <button id="tab-btn-procure" class="nav-tab px-4 py-2 text-sm font-medium rounded-full text-charcoal-400 hover:text-charcoal-50 transition-all">
          Smart Procurement
        </button>
      </nav>

      <!-- Connection Status & Controls -->
      <div class="flex items-center gap-3">
        <!-- Backend Server Status -->
        <div id="backend-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs">
          <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse" id="backend-dot"></span>
          <span class="text-charcoal-400 font-mono text-[11px]" id="backend-text">Checking API...</span>
        </div>
        <!-- Google Sheets Sync Status -->
        <div id="sheets-status" class="flex items-center gap-1.5 rounded-full border border-charcoal-700 bg-charcoal-800 px-3 py-1 text-xs cursor-pointer hover:border-charcoal-600 transition-all" title="Click to view Sheets details">
          <svg class="h-3.5 w-3.5 text-charcoal-400" id="sheets-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-charcoal-400 font-mono text-[11px]" id="sheets-text">Sheets: Sandbox</span>
        </div>
        <!-- Reset Button -->
        <button id="demo-reset-btn" class="hidden sm:flex items-center gap-1.5 rounded-md border border-charcoal-700 hover:border-charcoal-600 bg-charcoal-900 px-3 py-1.5 text-xs text-charcoal-200 hover:text-charcoal-50 font-medium transition-all" title="Reset Stock counts to default deficits">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
          </svg>
          Reset Demo
        </button>
      </div>
    </div>
  </header>

  <!-- Google Sheet Quick Setup Info Drawer -->
  <div id="sheets-info-drawer" class="hidden mx-auto max-w-7xl px-4 mt-4 sm:px-6 lg:px-8">
    <div class="bg-charcoal-800 border border-charcoal-700 rounded-xl p-4 text-xs font-mono text-charcoal-300 space-y-2.5 shadow-2xl">
      <div class="flex justify-between items-center text-charcoal-200 border-b border-charcoal-700 pb-2">
        <span class="font-bold uppercase text-[10px] tracking-wider text-emerald-500 flex items-center gap-1">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Google Sheets Sync Integration Guide
        </span>
        <button id="close-sheets-drawer" class="text-charcoal-400 hover:text-charcoal-200 cursor-pointer">✕ Close</button>
      </div>
      <p>
        1. Open your target Google Sheet and share it with edit access to this Service Account:
        <br />
        <code class="bg-charcoal-900 text-emerald-400 px-2 py-1 rounded block mt-1 select-all select-text font-semibold font-mono" id="sheets-email-display">loading service email...</code>
      </p>
      <p>
        2. Set these environment variables in your backend <code class="bg-charcoal-900 text-charcoal-100 px-1 rounded select-all font-mono">.env</code> configuration:
        <code class="bg-charcoal-900 text-charcoal-400 p-2 rounded block mt-1 leading-relaxed font-mono">
          GOOGLE_SHEET_ID=your_google_sheet_id_here
          <br />
          GOOGLE_SHEETS_CREDENTIALS_JSON=paste_service_account_json_content_here
        </code>
      </p>
      <div class="pt-2 border-t border-charcoal-700/50 flex items-center justify-between">
        <span>Spreadsheet Sync status: <strong id="sheets-drawer-status" class="text-amber-500 font-semibold font-mono">Sandbox Simulation (Offline Cache)</strong></span>
        <a href="#" id="sheets-link-url" target="_blank" class="hidden text-emerald-500 hover:text-emerald-400 underline font-bold flex items-center gap-1 transition-all">
          Open Spreadsheet 🔗
        </a>
      </div>
    </div>
  </div>

  <!-- Main Container -->
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- View 1: Voice Inventory (Mobile-First Card Container) -->
    <section id="view-voice" class="view-section block">
      <div class="mx-auto max-w-md bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden">
        <!-- View Header -->
        <div class="border-b border-charcoal-700 bg-charcoal-950/40 p-5 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-semibold text-charcoal-50">Staff Voice Inventory</h2>
            <p class="text-xs text-charcoal-400 mt-0.5">Walk the storage & call out items</p>
          </div>
          <!-- Offline badge -->
          <div id="offline-badge" class="flex items-center gap-1 rounded-full bg-emerald-950 border border-emerald-500/30 px-2.5 py-0.5 text-[10px] text-emerald-500 font-medium font-mono">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            Cloud Sync
          </div>
        </div>

        <div class="p-6 flex flex-col items-center">
          <!-- Live Ingredients Quick Status Bar -->
          <div class="w-full mb-6">
            <span class="text-xs font-semibold text-charcoal-400 block mb-2 font-mono uppercase tracking-wider">Current Deficit Levels:</span>
            <div class="grid grid-cols-2 gap-2 text-xs" id="voice-ingredients-grid">
              <!-- Dynamically populated ingredients -->
            </div>
          </div>

          <!-- Pulsing Record Button -->
          <div class="relative my-8 flex flex-col items-center justify-center">
            <button id="mic-record-btn" class="h-28 w-28 rounded-full bg-charcoal-700 border-4 border-charcoal-600 flex items-center justify-center text-charcoal-50 hover:text-emerald-500 transition-all shadow-lg hover:scale-105 active:scale-95 cursor-pointer z-10">
              <svg id="mic-icon" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </button>
            <!-- Recording Active Waves -->
            <div id="mic-pulse-ring" class="hidden absolute top-0 left-0 h-28 w-28 rounded-full border border-emerald-500/50 animate-mic-pulse"></div>
            
            <span id="mic-status-label" class="mt-4 text-sm font-semibold text-charcoal-400 font-mono tracking-wide">TAP TO COUNT</span>
          </div>

          <!-- Simulated Phrase Injectors (Reviewer controls) -->
          <div class="w-full border-t border-charcoal-700 pt-4 mt-2">
            <span class="text-xs font-semibold text-charcoal-400 font-mono tracking-wider block mb-2 uppercase">Or Simulate Voice Count:</span>
            <div class="flex flex-col gap-1.5">
              <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Onions, 9 bags">
                <span>"Onions, 9 bags"</span>
                <span class="text-[10px] bg-charcoal-700 text-charcoal-400 rounded px-1.5 font-mono">Fill deficiency</span>
              </button>
              <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Cheese, 7 blocks; Onions, 12 bags">
                <span>"Cheese, 7 blocks; Onions, 12 bags"</span>
                <span class="text-[10px] bg-charcoal-700 text-charcoal-400 rounded px-1.5 font-mono">Count multi-items</span>
              </button>
              <button class="voice-sim-btn w-full text-left rounded-lg bg-charcoal-900 border border-charcoal-700 hover:border-charcoal-600 p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 flex justify-between items-center transition-all" data-phrase="Tomato, 11 kg; Flour, 8 bags">
                <span>"Tomato, 11 kg; Flour, 8 bags"</span>
                <span class="text-[10px] bg-charcoal-700 text-charcoal-400 rounded px-1.5 font-mono">Update flour & tomato</span>
              </button>
            </div>
          </div>

          <!-- Clear Stocks & Add Ingredient Tools -->
          <div class="w-full mt-3 bg-charcoal-900/20 border border-charcoal-700/50 rounded-xl p-3">
            <button id="clear-stocks-btn" class="w-full text-center rounded-lg bg-rose-955/20 hover:bg-rose-955/40 border border-rose-500/30 py-2 px-2.5 text-xs text-rose-500 hover:text-rose-400 font-bold transition-all">
              🗑️ Clear Stocks to 0.0 (Fresh Count)
            </button>

            <button id="toggle-add-ing-btn" class="w-full text-center rounded-lg bg-charcoal-800 border border-charcoal-700 hover:border-charcoal-600 py-2 px-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 font-bold mt-2 transition-all">
              ➕ Register New Ingredient SKU
            </button>
            
            <div id="add-ing-form-container" class="hidden mt-3 space-y-3 bg-charcoal-950/50 p-3.5 rounded-lg border border-charcoal-700">
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Item Name</label>
                <input type="text" id="new-ing-name" placeholder="e.g. Avocado" class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none focus:border-emerald-500" />
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">SKU Code</label>
                  <input type="text" id="new-ing-sku" placeholder="SKU-AVO-06" class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none" />
                </div>
                <div>
                  <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Unit Type</label>
                  <input type="text" id="new-ing-unit" placeholder="boxes, bags, kg" class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Safety Par</label>
                  <input type="number" id="new-ing-par" placeholder="5" class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none" />
                </div>
                <div>
                  <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Cost / Unit ($)</label>
                  <input type="number" id="new-ing-cost" placeholder="18.50" class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-[10px] text-charcoal-400 font-mono uppercase tracking-wider mb-1">Supplier / Vendor</label>
                <input type="text" id="new-ing-vendor" placeholder="Fresh Produce Co." class="w-full bg-charcoal-800 border border-charcoal-700 rounded p-1.5 text-xs text-charcoal-50 focus:outline-none" />
              </div>
              <button id="save-new-ing-btn" class="w-full bg-emerald-500 hover:bg-emerald-600 text-charcoal-950 font-bold text-xs p-2 rounded-lg transition-all">
                Save Ingredient
              </button>
            </div>
          </div>

          <!-- Live Transcript Ticker -->
          <div class="w-full mt-6 bg-charcoal-950 border border-charcoal-700 rounded-xl p-4">
            <span class="text-[10px] font-bold text-emerald-500 font-mono tracking-wider block mb-1 uppercase">Live Pseudo-Transcript Ticker:</span>
            <div id="transcript-ticker" class="text-sm font-mono text-charcoal-200 italic min-h-6">
              "Standing by... Speak inventory or select a simulation shortcut."
            </div>
          </div>

          <!-- Parsed Stock Update Result -->
          <div id="voice-sync-results" class="w-full mt-4 hidden">
            <div class="rounded-xl border border-emerald-500/30 bg-emerald-950/10 p-4">
              <span class="text-[11px] font-bold text-emerald-500 font-mono uppercase block mb-2">Synced Stock Adjustments:</span>
              <ul class="space-y-1 text-xs font-mono" id="voice-updated-list">
                <!-- Dynamically populated -->
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- View 2: Invoice Scanner (Split-Screen Audit Dashboard) -->
    <section id="view-invoice" class="view-section hidden">
      <div class="bg-charcoal-800 border border-charcoal-700 rounded-2xl shadow-xl overflow-hidden p-6">
        <div class="flex flex-col lg:flex-row gap-6">
          
          <!-- Left Panel: Drag-and-Drop / Upload / Simulated Invoices -->
          <div class="w-full lg:w-1/3 flex flex-col gap-4">
            <h3 class="text-base font-semibold text-charcoal-50 font-mono tracking-wide">1. Upload Supplier Invoice</h3>
            
            <!-- Drag & Drop Zone -->
            <div id="invoice-dropzone" class="border-2 border-dashed border-charcoal-700 hover:border-emerald-500/50 bg-charcoal-900 rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer transition-all min-h-[220px]">
              <input type="file" id="invoice-file-input" class="hidden" accept="image/*,application/pdf" />
              <svg class="h-10 w-10 text-charcoal-400 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="text-sm font-medium text-charcoal-50">Drag invoice image here</span>
              <span class="text-xs text-charcoal-400 mt-1">or click to upload PDF/JPEG</span>
            </div>

            <!-- Demo Simulate Quick Buttons -->
            <div class="bg-charcoal-900 border border-charcoal-700 rounded-xl p-4">
              <span class="text-xs font-semibold text-charcoal-400 font-mono tracking-wider block mb-3 uppercase">Simulation Audits:</span>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                <button class="invoice-sim-btn bg-charcoal-800 border border-charcoal-700 hover:border-charcoal-600 rounded-lg p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 text-left transition-all" data-vendor="Sysco">
                  <div class="font-bold text-emerald-500">Sysco Invoice</div>
                  <div class="text-[10px] text-charcoal-400 mt-0.5">Cheese price increase + Flour normal</div>
                </button>
                <button class="invoice-sim-btn bg-charcoal-800 border border-charcoal-700 hover:border-charcoal-600 rounded-lg p-2.5 text-xs text-charcoal-200 hover:text-charcoal-50 text-left transition-all" data-vendor="Fresh">
                  <div class="font-bold text-emerald-500">Fresh Produce Co.</div>
                  <div class="text-[10px] text-charcoal-400 mt-0.5">Onion price spike + Tomato normal</div>
                </button>
              </div>
            </div>
          </div>

          <!-- Right Panel: OCR Results & Split Screen Audit -->
          <div class="w-full lg:w-2/3 border border-charcoal-700 bg-charcoal-900 rounded-xl p-6 min-h-[350px] flex flex-col">
            <!-- Loading Skeleton (Hidden by default) -->
            <div id="invoice-loading-skeleton" class="hidden flex-1 flex flex-col justify-center py-12 px-6">
              <div class="flex items-center justify-center space-x-2 animate-pulse mb-6">
                <div class="h-3 w-3 bg-emerald-500 rounded-full"></div>
                <div class="h-3 w-3 bg-emerald-500 rounded-full animate-delay-100"></div>
                <div class="h-3 w-3 bg-emerald-500 rounded-full animate-delay-200"></div>
              </div>
              <div class="space-y-4 max-w-lg mx-auto w-full">
                <div class="h-4 bg-charcoal-700 rounded w-1/3"></div>
                <div class="h-4 bg-charcoal-700 rounded w-1/2"></div>
                <div class="h-10 bg-charcoal-700 rounded w-full mt-4"></div>
                <div class="h-10 bg-charcoal-700 rounded w-full"></div>
              </div>
            </div>

            <!-- Empty State -->
            <div id="invoice-empty-state" class="flex-1 flex flex-col items-center justify-center text-center text-charcoal-400 py-12">
              <svg class="h-12 w-12 text-charcoal-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <h4 class="text-sm font-semibold text-charcoal-200">No Audits Performed Yet</h4>
              <p class="text-xs max-w-sm mt-1">Upload a supplier invoice to automatically parse prices and run historical audits for price increases.</p>
            </div>

            <!-- Parsed Results Table (Hidden by default) -->
            <div id="invoice-results-panel" class="hidden flex-1 flex flex-col justify-between">
              <div>
                <!-- Metadata Bar -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-charcoal-700 pb-4 mb-4 gap-2">
                  <div>
                    <span class="text-xs text-charcoal-400 font-mono">SUPPLIER AUDITED:</span>
                    <h4 id="invoice-vendor-name" class="text-base font-bold text-charcoal-50">Fresh Produce Co.</h4>
                  </div>
                  <div class="text-left sm:text-right">
                    <span class="text-xs text-charcoal-400 font-mono">INVOICE:</span>
                    <p id="invoice-doc-number" class="text-sm font-semibold text-charcoal-200">#INV-9812-B</p>
                  </div>
                </div>

                <!-- Warnings Banner -->
                <div id="anomaly-banner" class="hidden rounded-lg bg-amber-950/20 border border-amber-500/30 p-3.5 mb-5 flex items-start gap-3">
                  <svg class="h-5 w-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <div>
                    <span class="text-xs font-semibold text-amber-500 block">Unit Cost Inflation Detected!</span>
                    <span class="text-xs text-charcoal-400 mt-0.5 block" id="anomaly-banner-text">Some line items are priced higher than our historical baseline. Audited costs have been flagged.</span>
                  </div>
                </div>

                <!-- Extracted Items Table -->
                <div class="overflow-x-auto">
                  <table class="w-full border-collapse text-left text-xs">
                    <thead>
                      <tr class="border-b border-charcoal-700 text-charcoal-400 font-mono">
                        <th class="py-2.5 font-medium">Item Name</th>
                        <th class="py-2.5 font-medium">Quantity</th>
                        <th class="py-2.5 font-medium">Unit Price</th>
                        <th class="py-2.5 font-medium">Baseline Price</th>
                        <th class="py-2.5 font-medium">Status / Audit</th>
                      </tr>
                    </thead>
                    <tbody id="invoice-items-tbody" class="divide-y divide-charcoal-700/50">
                      <!-- Filled dynamically -->
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- Action Bar -->
              <div class="border-t border-charcoal-700 pt-4 mt-6 flex justify-between items-center text-xs">
                <span class="text-charcoal-400">Total Audited Amount: <strong id="invoice-total-cost" class="text-charcoal-50 font-mono">$0.00</strong></span>
                <span class="text-[10px] font-mono text-emerald-500 bg-emerald-950 border border-emerald-500/20 px-2 py-1 rounded-md">Baseline Prices Updated</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- View 3: Smart Procurement Dashboard (Desktop View) -->
    <section id="view-procure" class="view-section hidden">
      <!-- Analytics Summary Bar -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-charcoal-800 border border-charcoal-700 rounded-xl p-5 shadow">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold text-charcoal-400 font-mono uppercase tracking-wider">Total Waste Saved This Month</span>
            <span class="p-1.5 rounded-lg bg-emerald-950/50 text-emerald-500">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
          </div>
          <h4 id="stat-waste-saved" class="text-3xl font-bold text-charcoal-50 mt-2 font-mono">$452.00</h4>
          <span class="text-[10px] text-emerald-500 mt-1 block">✔ AI Over-ordering prevention logic active</span>
        </div>

        <div class="bg-charcoal-800 border border-charcoal-700 rounded-xl p-5 shadow">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold text-charcoal-400 font-mono uppercase tracking-wider">Critical Stock Alerts</span>
            <span class="p-1.5 rounded-lg bg-amber-950/50 text-amber-500">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </span>
