  <script>
    // Configuration
    const BACKEND_BASE_URL = import.meta.env.PUBLIC_BACKEND_URL || (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' ? 'http://localhost:8000' : '');
    let isBackendOnline = false;
    let sheetsConfig = { is_mock: true, sheet_id: '', share_email: '' };

    // Local State fallback database - mirrors seeded backend DB structure
    let localIngredients = [
      { id: 1, SKU_code: 'SKU-ONN-01', item_name: 'Onions', current_stock: 4.0, safety_par_level: 10.0, unit_type: 'bags', cost_per_unit: 15.00, vendor_name: 'Fresh Produce Co.' },
      { id: 2, SKU_code: 'SKU-CHS-02', item_name: 'Cheddar Cheese', current_stock: 3.0, safety_par_level: 8.0, unit_type: 'blocks', cost_per_unit: 12.00, vendor_name: 'Sysco' },
      { id: 3, SKU_code: 'SKU-TMT-03', item_name: 'Tomato', current_stock: 2.0, safety_par_level: 12.0, unit_type: 'kg', cost_per_unit: 5.00, vendor_name: 'Fresh Produce Co.' },
      { id: 4, SKU_code: 'SKU-BFF-04', item_name: 'Beef Patties', current_stock: 22.0, safety_par_level: 15.0, unit_type: 'boxes', cost_per_unit: 45.00, vendor_name: 'Sysco' },
      { id: 5, SKU_code: 'SKU-FLR-05', item_name: 'Flour', current_stock: 6.5, safety_par_level: 8.0, unit_type: 'bags', cost_per_unit: 8.50, vendor_name: 'Sysco' }
    ];

    // Current PO items cache for editing
    let activePOData = null;
    let editingPOItemIndex = -1;
    let editingPOVendorName = '';

    // Initialize elements
    document.addEventListener('DOMContentLoaded', () => {
      checkBackendHealth();
      initNavigation();
      initVoiceView();
      initInvoiceView();
      initProcureView();
      initSheetsUI();
      
      // Global Reset click
      document.getElementById('demo-reset-btn').addEventListener('click', handleGlobalReset);
    });

    // Handle Sheets Setup info drawer toggles
    function initSheetsUI() {
      const statusBadge = document.getElementById('sheets-status');
      const infoDrawer = document.getElementById('sheets-info-drawer');
      const closeDrawer = document.getElementById('close-sheets-drawer');

      statusBadge.addEventListener('click', () => {
        infoDrawer.classList.toggle('hidden');
      });

      closeDrawer.addEventListener('click', () => {
        infoDrawer.classList.add('hidden');
      });
    }

    // Toast function
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      
      const isError = type === 'error';
      const isWarn = type === 'warning';
      
      let borderCol = 'border-emerald-500/30';
      let bgCol = 'bg-emerald-950/90';
      let textCol = 'text-emerald-500';
      
      if (isError) {
        borderCol = 'border-rose-500/30';
        bgCol = 'bg-rose-950/90';
        textCol = 'text-rose-500';
      } else if (isWarn) {
        borderCol = 'border-amber-500/30';
        bgCol = 'bg-amber-950/90';
        textCol = 'text-amber-500';
      }
      
      toast.className = `border ${borderCol} ${bgCol} text-xs font-mono p-4 rounded-xl shadow-2xl flex justify-between items-center gap-4 transition-all duration-300 transform translate-y-4 opacity-0`;
      toast.innerHTML = `
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full ${isError ? 'bg-rose-500' : isWarn ? 'bg-amber-500' : 'bg-emerald-500'}"></span>
          <span class="text-charcoal-50">${message}</span>
        </div>
        <button class="text-charcoal-400 hover:text-charcoal-50 text-[10px]" onclick="this.parentElement.remove()">✕</button>
      `;
      
      container.appendChild(toast);
      
      // Animate in
      setTimeout(() => {
        toast.classList.remove('translate-y-4', 'opacity-0');
      }, 50);

      // Remove after 5 seconds
      setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 5000);
    }

    // Health Check API
    async function checkBackendHealth() {
      const dot = document.getElementById('backend-dot');
      const text = document.getElementById('backend-text');
      
      try {
        const res = await fetch(BACKEND_BASE_URL + '/');
        if (res.ok) {
          isBackendOnline = true;
          dot.className = 'h-2 w-2 rounded-full bg-emerald-500';
          text.innerText = 'API: Online';
          text.className = 'text-emerald-500 font-mono text-[11px]';
          // Load ingredients from backend
          fetchIngredientsFromBackend();
          // Load sheets configuration
          fetchSheetsConfig();
        } else {
          throw new Error('Not OK');
        }
      } catch (e) {
        isBackendOnline = false;
        dot.className = 'h-2 w-2 rounded-full bg-amber-500 animate-pulse';
        text.innerText = 'API: Sandbox Mock Mode';
        text.className = 'text-amber-500 font-mono text-[11px]';
        
        // Reset Sheets config to mock in offline mode
        sheetsConfig = { is_mock: true, sheet_id: '', share_email: '' };
        updateSheetsUI();
        
        // Render local state in UI
        renderVoiceIngredients();
        refreshProcurementDrafts();
      }
    }

    async function fetchSheetsConfig() {
      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/sheets/config`);
        if (res.ok) {
          sheetsConfig = await res.json();
          updateSheetsUI();
        }
      } catch (e) {
        console.error('Failed to fetch Sheets configuration details:', e);
      }
    }

    function updateSheetsUI() {
      const badge = document.getElementById('sheets-text');
      const icon = document.getElementById('sheets-icon');
      const drawerStatus = document.getElementById('sheets-drawer-status');
      const emailDisplay = document.getElementById('sheets-email-display');
      const linkUrl = document.getElementById('sheets-link-url');
      
      if (sheetsConfig.is_mock) {
        badge.innerText = 'Sheets: Sandbox';
        badge.className = 'text-charcoal-400 font-mono text-[11px]';
        icon.setAttribute('class', 'h-3.5 w-3.5 text-charcoal-400');
        
        drawerStatus.innerText = 'Sandbox Simulation (Offline Cache)';
        drawerStatus.className = 'text-amber-500 font-semibold font-mono';
        emailDisplay.innerText = 'gcp-service-account@not-configured.iam.gserviceaccount.com';
        linkUrl.classList.add('hidden');
      } else {
        badge.innerText = 'Sheets: Linked';
        badge.className = 'text-emerald-500 font-mono text-[11px]';
        icon.setAttribute('class', 'h-3.5 w-3.5 text-emerald-500');
        
        drawerStatus.innerText = 'Linked & Synchronizing';
        drawerStatus.className = 'text-emerald-500 font-semibold font-mono';
        emailDisplay.innerText = sheetsConfig.share_email;
        linkUrl.href = `https://docs.google.com/spreadsheets/d/${sheetsConfig.sheet_id}`;
        linkUrl.classList.remove('hidden');
      }
    }

    async function fetchIngredientsFromBackend() {
      try {
        const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients`, {
          headers: {
            'X-Tenant-ID': '1'
          }
        });
        if (res.ok) {
          localIngredients = await res.json();
          renderVoiceIngredients();
          refreshProcurementDrafts();
        }
      } catch (e) {
        console.error('Failed to fetch ingredients from backend:', e);
      }
    }

    async function handleGlobalReset() {
      if (isBackendOnline) {
        try {
          const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/reset`, { method: 'POST' });
          if (res.ok) {
            showToast('Database stock metrics reset to deficits');
            fetchIngredientsFromBackend();
          }
        } catch (e) {
          console.error(e);
        }
      } else {
        // Reset local state variables to default deficit values
        localIngredients[0].current_stock = 4.0; localIngredients[0].cost_per_unit = 15.00;
        localIngredients[1].current_stock = 3.0; localIngredients[1].cost_per_unit = 12.00;
        localIngredients[2].current_stock = 2.0; localIngredients[2].cost_per_unit = 5.00;
        localIngredients[3].current_stock = 22.0; localIngredients[3].cost_per_unit = 45.00;
        localIngredients[4].current_stock = 6.5; localIngredients[4].cost_per_unit = 8.50;
        
        renderVoiceIngredients();
        refreshProcurementDrafts();
        
        // Reset invoice auditor panel
        document.getElementById('invoice-results-panel').classList.add('hidden');
        document.getElementById('invoice-empty-state').classList.remove('hidden');
        
        showToast('Local database mock values reset to default deficits');
      }
    }

    // Tabs Navigation Setup
    function initNavigation() {
      const desktopTabs = {
        'tab-btn-voice': 'view-voice',
        'tab-btn-invoice': 'view-invoice',
        'tab-btn-procure': 'view-procure'
      };

      const mobileTabs = {
        'mobile-tab-btn-voice': 'view-voice',
        'mobile-tab-btn-invoice': 'view-invoice',
        'mobile-tab-btn-procure': 'view-procure'
      };

      function switchSection(targetId, activeBtnId) {
        // Hide all views
        document.querySelectorAll('.view-section').forEach(sec => sec.classList.add('hidden'));
        // Show target view
        document.getElementById(targetId).classList.remove('hidden');

        // Toggle desktop active classes
        document.querySelectorAll('.nav-tab').forEach(btn => {
          btn.className = 'nav-tab px-4 py-2 text-sm font-medium rounded-full text-charcoal-400 hover:text-charcoal-50 transition-all';
        });
        
        // Find desktop matching button
        const desktopBtnId = activeBtnId.replace('mobile-', '');
        const activeDesktopBtn = document.getElementById(desktopBtnId) || document.getElementById(activeBtnId);
        if (activeDesktopBtn) {
          activeDesktopBtn.className = 'nav-tab active-tab px-4 py-2 text-sm font-medium rounded-full bg-emerald-500 text-charcoal-950 font-semibold transition-all';
        }

        // Toggle mobile active classes
        document.querySelectorAll('.mobile-nav-tab').forEach(btn => {
          btn.className = 'mobile-nav-tab flex flex-col items-center justify-center flex-1 text-charcoal-400';
        });
        
        // Find mobile matching button
        const mobBtnId = activeBtnId.startsWith('mobile-') ? activeBtnId : 'mobile-' + activeBtnId;
        const activeMobileBtn = document.getElementById(mobBtnId);
        if (activeMobileBtn) {
          activeMobileBtn.className = 'mobile-nav-tab flex flex-col items-center justify-center flex-1 text-emerald-500 font-semibold';
        }
      }

      // Add desktop click listeners
      Object.keys(desktopTabs).forEach(btnId => {
        document.getElementById(btnId).addEventListener('click', () => {
          switchSection(desktopTabs[btnId], btnId);
        });
      });

      // Add mobile click listeners
      Object.keys(mobileTabs).forEach(btnId => {
        document.getElementById(btnId).addEventListener('click', () => {
          switchSection(mobileTabs[btnId], btnId);
        });
      });

      // Style active tab initially
      document.getElementById('tab-btn-voice').className = 'nav-tab active-tab px-4 py-2 text-sm font-medium rounded-full bg-emerald-500 text-charcoal-950 font-semibold transition-all';
    }


    let mediaRecorder = null;
    let audioChunks = [];

    // ─── VOICE VIEW CODE ───
    function initVoiceView() {
      renderVoiceIngredients();

      const recordBtn = document.getElementById('mic-record-btn');
      const micStatusLabel = document.getElementById('mic-status-label');
      const micPulseRing = document.getElementById('mic-pulse-ring');
      const ticker = document.getElementById('transcript-ticker');
      const voiceResults = document.getElementById('voice-sync-results');
      const updatedList = document.getElementById('voice-updated-list');

      let isRecording = false;

      recordBtn.addEventListener('click', async () => {
        isRecording = !isRecording;
        if (isRecording) {
          try {
            // Request microphone access
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            audioChunks = [];
            mediaRecorder = new MediaRecorder(stream);
            
            mediaRecorder.ondataavailable = (event) => {
              if (event.data.size > 0) {
                audioChunks.push(event.data);
              }
            };
            
            mediaRecorder.onstop = async () => {
              const audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
              const audioFile = new File([audioBlob], 'voice_inventory.wav', { type: 'audio/wav' });
              
              micStatusLabel.innerText = 'PROCESSING...';
              micStatusLabel.className = 'mt-4 text-sm font-semibold text-charcoal-400 font-mono tracking-wide';
              
              await handleVoiceInventorySync(audioFile);
              micStatusLabel.innerText = 'TAP TO COUNT';
            };
            
            mediaRecorder.start();
            
            // Turn ON recording UI
            recordBtn.classList.remove('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
            recordBtn.classList.add('bg-emerald-500', 'border-emerald-600', 'text-charcoal-950');
            micPulseRing.classList.remove('hidden');
            micStatusLabel.innerText = 'LISTENING...';
            micStatusLabel.className = 'mt-4 text-sm font-bold text-emerald-500 font-mono tracking-wide animate-pulse';
            ticker.innerText = '"Recording microphone... Speak counts, then tap again to stop."';
          } catch (e) {
            console.error('Microphone access denied:', e);
            showToast('Microphone access denied. Using simulation instead.', 'warning');
            
            // Revert record state
            isRecording = false;
            // Trigger simulation
            const simulatedPhrases = [
              "Onions, 9 bags",
              "Cheese, 7 blocks; Onions, 12 bags",
              "Tomato, 11 kg; Flour, 8 bags"
            ];
            const randPhrase = simulatedPhrases[Math.floor(Math.random() * simulatedPhrases.length)];
            await handleVoiceInventorySync(randPhrase);
          }
        } else {
          // Stop recording
          if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            mediaRecorder.stop();
            mediaRecorder.stream.getTracks().forEach(track => track.stop());
            
            // Reset UI
            recordBtn.classList.remove('bg-emerald-500', 'border-emerald-600', 'text-charcoal-950');
            recordBtn.classList.add('bg-charcoal-700', 'border-charcoal-600', 'text-charcoal-50');
            micPulseRing.classList.add('hidden');
          }
        }
      });

      // Quick simulated click handlers
      document.querySelectorAll('.voice-sim-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const phrase = btn.getAttribute('data-phrase');
          handleVoiceInventorySync(phrase);
        });
      });

      // Clear stocks event listener
      document.getElementById('clear-stocks-btn').addEventListener('click', async () => {
        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients/clear-stocks`, {
              method: 'POST',
              headers: {
                'X-Tenant-ID': '1'
              }
            });
            if (res.ok) {
              showToast('Database stock metrics cleared to 0.0');
              fetchIngredientsFromBackend();
            }
          } catch (e) {
            console.error(e);
          }
        } else {
          localIngredients.forEach(ing => ing.current_stock = 0.0);
          renderVoiceIngredients();
          refreshProcurementDrafts();
          showToast('Local mock database stocks cleared to 0.0');
        }
      });

      // Toggle Add Ingredient form visibility
      const toggleFormBtn = document.getElementById('toggle-add-ing-btn');
      const formContainer = document.getElementById('add-ing-form-container');
      toggleFormBtn.addEventListener('click', () => {
        formContainer.classList.toggle('hidden');
        if (formContainer.classList.contains('hidden')) {
          toggleFormBtn.innerText = '➕ Register New Ingredient SKU';
        } else {
          toggleFormBtn.innerText = '✕ Close Registration Form';
        }
      });

      // Save ingredient click handler
      document.getElementById('save-new-ing-btn').addEventListener('click', async () => {
        const name = document.getElementById('new-ing-name').value.trim();
        const sku = document.getElementById('new-ing-sku').value.trim();
        const unit = document.getElementById('new-ing-unit').value.trim();
        const par = parseFloat(document.getElementById('new-ing-par').value);
        const cost = parseFloat(document.getElementById('new-ing-cost').value);
        const vendor = document.getElementById('new-ing-vendor').value.trim();

        if (!name || !sku || !unit || isNaN(par) || isNaN(cost) || !vendor) {
          showToast('Please fill out all registration fields.', 'error');
          return;
        }

        const payload = {
          SKU_code: sku,
          item_name: name,
          current_stock: 0.0,
          safety_par_level: par,
          unit_type: unit,
          cost_per_unit: cost,
          vendor_name: vendor
        };

        if (isBackendOnline) {
          try {
            const res = await fetch(`${BACKEND_BASE_URL}/api/ingredients`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Tenant-ID': '1'
              },
              body: JSON.stringify(payload)
            });

            if (res.ok) {
              showToast(`${name} registered successfully!`);
              // Clear fields
              document.getElementById('new-ing-name').value = '';
              document.getElementById('new-ing-sku').value = '';
              document.getElementById('new-ing-unit').value = '';
              document.getElementById('new-ing-par').value = '';
              document.getElementById('new-ing-cost').value = '';
              document.getElementById('new-ing-vendor').value = '';
              formContainer.classList.add('hidden');
              toggleFormBtn.innerText = '➕ Register New Ingredient SKU';
              
              fetchIngredientsFromBackend();
            } else {
              const err = await res.json();
              showToast(err.detail || 'Failed to save ingredient', 'error');
            }
          } catch (e) {
            console.error(e);
            showToast('API connection error', 'error');
          }
        } else {
          // Push locally
          const newId = localIngredients.length + 1;
          localIngredients.push({ id: newId, ...payload });
          
          showToast(`${name} registered locally! Ready for counts.`);
          // Clear fields
          document.getElementById('new-ing-name').value = '';
          document.getElementById('new-ing-sku').value = '';
          document.getElementById('new-ing-unit').value = '';
          document.getElementById('new-ing-par').value = '';
          document.getElementById('new-ing-cost').value = '';
          document.getElementById('new-ing-vendor').value = '';
          formContainer.classList.add('hidden');
          toggleFormBtn.innerText = '➕ Register New Ingredient SKU';
          
          renderVoiceIngredients();
          refreshProcurementDrafts();
        }
      });
    }

    function renderVoiceIngredients() {
      const grid = document.getElementById('voice-ingredients-grid');
      grid.innerHTML = '';

      localIngredients.forEach(ing => {
        const isDeficit = ing.current_stock < ing.safety_par_level;
        const colorClass = isDeficit ? 'border-amber-500/20 bg-amber-950/10 text-amber-500' : 'border-charcoal-700 bg-charcoal-900 text-charcoal-400';
        grid.innerHTML += `
          <div class="border p-2.5 rounded-lg ${colorClass} flex flex-col justify-between font-mono">
            <span class="font-bold text-charcoal-50 truncate">${ing.item_name}</span>
            <div class="flex justify-between items-center mt-1 text-[11px]">
              <span>Stock: <strong>${ing.current_stock}</strong></span>
              <span>Par: <strong>${ing.safety_par_level}</strong></span>
            </div>
          </div>
        `;
      });
    }

    async function handleVoiceInventorySync(input) {
      const ticker = document.getElementById('transcript-ticker');
      const voiceResults = document.getElementById('voice-sync-results');
      const updatedList = document.getElementById('voice-updated-list');

      const isFile = input instanceof File;
      if (!isFile) {
        ticker.innerText = `"${input}"`;
      } else {
        ticker.innerText = '"Uploading and transcribing voice counts..."';
      }

      if (isBackendOnline) {
        try {
          let file = input;
          if (!isFile) {
            // Generate simulated audio file if phrase button was clicked
            const blob = new Blob([input], { type: 'text/plain' });
            file = new File([blob], 'simulated_audio.wav', { type: 'audio/wav' });
          }

          const formData = new FormData();
          formData.append('file', file);
          formData.append('tenant_id', '1');

          const res = await fetch(`${BACKEND_BASE_URL}/api/inventory/voice-upload`, {
            method: 'POST',
            headers: {
              'X-Tenant-ID': '1'
            },
            body: formData
          });

          if (res.ok) {
            const data = await res.json();
            ticker.innerText = `"${data.transcript}"`;
            
            // Pop updated lists
            updatedList.innerHTML = '';
            data.updated_ingredients.forEach(item => {
              updatedList.innerHTML += `
                <li class="flex justify-between items-center text-charcoal-200">
                  <span>${item.item_name}:</span>
                  <span>${item.old_stock} ➔ <strong class="text-emerald-500 font-bold">${item.new_stock}</strong> ${item.unit}</span>
                </li>
              `;
            });
            voiceResults.classList.remove('hidden');
            showToast('Voice Count synced with backend database!');
            fetchIngredientsFromBackend();
          } else {
            throw new Error('API Sync Failed');
          }
        } catch (e) {
          console.error(e);
          showToast('Failed to connect to API, running local fallback sync.', 'warning');
          runLocalVoiceSync(isFile ? "Onions, 9 bags; Cheddar Cheese, 5 blocks" : input);
        }
      } else {
        runLocalVoiceSync(isFile ? "Onions, 9 bags; Cheddar Cheese, 5 blocks" : input);
      }
    }

    function runLocalVoiceSync(phrase) {
      const voiceResults = document.getElementById('voice-sync-results');
      const updatedList = document.getElementById('voice-updated-list');
      
      // Parse phrases manually: "Onions, 9 bags" -> Onions, 9.0, bags
      const parts = phrase.split(';');
      updatedList.innerHTML = '';

      parts.forEach(part => {
        const itemMatch = part.trim().match(/([a-zA-Z\s]+),\s*([0-9.]+)\s*([a-zA-Z]+)/);
        if (itemMatch) {
          const rawName = itemMatch[1].trim();
          const quantity = parseFloat(itemMatch[2]);
          const unit = itemMatch[3].trim();

          // Search inside local inventory
          const ingredient = localIngredients.find(ing => ing.item_name.toLowerCase().includes(rawName.toLowerCase()));
          if (ingredient) {
            const oldStock = ingredient.current_stock;
            ingredient.current_stock = quantity;
            
            updatedList.innerHTML += `
              <li class="flex justify-between items-center text-charcoal-200">
                <span>${ingredient.item_name}:</span>
                <span>${oldStock} ➔ <strong class="text-emerald-500 font-bold">${ingredient.current_stock}</strong> ${ingredient.unit_type}</span>
              </li>
            `;
          }
        }
      });

      renderVoiceIngredients();
      refreshProcurementDrafts();
      voiceResults.classList.remove('hidden');
      showToast('Offline cache active: stock saved locally!');
    }


    // ─── INVOICE SCANNER CODE ───
    function initInvoiceView() {
      const dropzone = document.getElementById('invoice-dropzone');
      const fileInput = document.getElementById('invoice-file-input');
      const emptyState = document.getElementById('invoice-empty-state');
      const loadingSkeleton = document.getElementById('invoice-loading-skeleton');
      const resultsPanel = document.getElementById('invoice-results-panel');

      // Click to choose file trigger
      dropzone.addEventListener('click', () => fileInput.click());

      // File drag-over logic
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('border-emerald-500', 'bg-emerald-950/10');
      });

      dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('border-emerald-500', 'bg-emerald-950/10');
      });

      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-emerald-500', 'bg-emerald-950/10');
        if (e.dataTransfer.files.length > 0) {
          handleInvoiceUpload(e.dataTransfer.files[0]);
        }
      });

      fileInput.addEventListener('change', () => {
        if (fileInput.files.length > 0) {
          handleInvoiceUpload(fileInput.files[0]);
        }
      });

      // Click simulate invoice buttons
      document.querySelectorAll('.invoice-sim-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation(); // Stop trigger input click
          const vendor = btn.getAttribute('data-vendor');
          simulateInvoiceAudit(vendor);
        });
      });
    }

    async function handleInvoiceUpload(file) {
      const emptyState = document.getElementById('invoice-empty-state');
      const loadingSkeleton = document.getElementById('invoice-loading-skeleton');
      const resultsPanel = document.getElementById('invoice-results-panel');

      // Toggle loading states
      emptyState.classList.add('hidden');
      resultsPanel.classList.add('hidden');
      loadingSkeleton.classList.remove('hidden');

      if (isBackendOnline) {
        try {
          const formData = new FormData();
          formData.append('file', file);
          formData.append('tenant_id', '1');

          const res = await fetch(`${BACKEND_BASE_URL}/api/procurement/upload-invoice`, {
            method: 'POST',
            headers: {
              'X-Tenant-ID': '1'
            },
            body: formData
          });

          if (res.ok) {
            const data = await res.json();
            renderInvoiceAuditData(data);
            showToast('Invoice uploaded & price audited successfully!');
            fetchIngredientsFromBackend();
          } else {
            throw new Error('Upload Audit Failed');
          }
        } catch (e) {
          console.error(e);
          showToast('Backend upload failed, running local mock audit instead.', 'warning');
          simulateInvoiceAudit(file.name.includes('sys') ? 'Sysco' : 'Fresh');
        }
      } else {
        // Fallback simulate
        setTimeout(() => {
          simulateInvoiceAudit(file.name.toLowerCase().includes('sys') ? 'Sysco' : 'Fresh');
        }, 1500);
      }
    }

    function simulateInvoiceAudit(vendorKey) {
      let data = null;

      if (vendorKey === 'Sysco') {
        data = {
          vendor_name: 'Sysco Foodservices',
          invoice_number: 'INV-SYS-99418',
          total_amount: 215.50,
          items: [
            { item_name: 'Cheddar Cheese', quantity: 10.0, unit_price: 15.50, price_anomaly: true, previous_price: 12.00 },
            { item_name: 'Flour', quantity: 5.0, unit_price: 8.50, price_anomaly: false, previous_price: 8.50 }
          ]
        };
      } else {
        data = {
          vendor_name: 'Fresh Produce Co.',
          invoice_number: 'INV-FPC-88127',
          total_amount: 145.00,
          items: [
            { item_name: 'Onions', quantity: 6.0, unit_price: 19.50, price_anomaly: true, previous_price: 15.00 },
            { item_name: 'Tomato', quantity: 8.0, unit_price: 5.00, price_anomaly: false, previous_price: 5.00 }
          ]
        };
      }

      // Sync local state as if the database updated baseline values
      data.items.forEach(item => {
