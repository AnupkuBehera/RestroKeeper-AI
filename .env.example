# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key_here

# Supabase configuration (Optional for local execution fallback, database will fallback to SQLite if not provided)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# Database Connection URL (Optional - if left empty, SQLite will be used as a local fallback database)
DATABASE_URL=postgresql://username:password@db.supabase.co:5432/postgres
